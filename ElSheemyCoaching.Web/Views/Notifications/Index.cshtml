@model IEnumerable<ElSheemyCoaching.Core.Entities.InAppNotification>
@using Microsoft.AspNetCore.Localization
@{
    ViewData["Title"] = "الإشعارات";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isArabic = requestCulture?.RequestCulture.Culture.Name.StartsWith("ar") ?? true;
}

<section class="max-w-4xl mx-auto px-4 py-10">
    <div class="mb-8 border-b border-white/5 pb-6">
        <h1 class="text-2xl font-extrabold mb-1">@(isArabic ? "الإشعارات" : "Notifications")</h1>
        <p class="text-dark-400 text-sm">@(isArabic ? "تحديثات وإشعارات حسابك" : "Updates and alerts for your account")</p>
    </div>

    @if (Model.Any())
    {
        <div class="space-y-4">
            @foreach (var notification in Model)
            {
                <div class="bg-dark-900/50 @(!notification.IsRead ? "border-brand-500/30 bg-brand-900/10" : "border-white/5") border rounded-2xl p-5 transition-all">
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-full shrink-0 flex items-center justify-center @(!notification.IsRead ? "bg-brand-600/20 text-brand-400" : "bg-dark-800 text-dark-400")">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                            </svg>
                        </div>
                        <div class="flex-1">
                            <div class="flex items-start justify-between gap-4 mb-1">
                                <h3 class="font-bold text-white @(!notification.IsRead ? "text-brand-400" : "")">
                                    @(isArabic ? notification.TitleAr : notification.TitleEn)
                                </h3>
                                <span class="text-xs text-dark-500 whitespace-nowrap">@notification.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                            </div>
                            <p class="text-dark-300 text-sm mb-3">
                                @(isArabic ? notification.MessageAr : notification.MessageEn)
                            </p>
                            @if (!string.IsNullOrEmpty(notification.ActionUrl))
                            {
                                <form asp-controller="Notifications" asp-action="MarkAsRead" asp-route-id="@notification.Id" method="post" class="inline">
                                    <button type="submit" class="text-brand-400 hover:text-brand-300 text-sm font-medium transition-colors flex items-center gap-1.5">
                                        @(isArabic ? "عرض التفاصيل و التحميل" : "View Details & Download")
                                        <svg class="w-4 h-4 @(isArabic ? "rotate-180" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="bg-dark-900/50 border border-white/5 rounded-2xl p-12 text-center">
            <svg class="w-16 h-16 text-dark-700 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
            <p class="text-dark-500">@(isArabic ? "ليس لديك أي إشعارات جديدة" : "You don't have any notifications yet")</p>
        </div>
    }
</section>
