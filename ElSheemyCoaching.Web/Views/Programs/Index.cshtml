@model IEnumerable<ElSheemyCoaching.Core.Entities.WorkoutProgram>
@using Microsoft.AspNetCore.Localization
@{
    ViewData["Title"] = "البرامج";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isArabic = requestCulture?.RequestCulture.Culture.Name.StartsWith("ar") ?? true;
}

<section class="max-w-7xl mx-auto px-4 py-16">
    <div class="text-center mb-12">
        <h1 class="text-3xl sm:text-4xl font-extrabold mb-4">
            @(isArabic ? "برامج التدريب" : "Training Programs")
        </h1>
        <p class="text-dark-400 text-lg max-w-xl mx-auto">
            @(isArabic
                ? "اختر البرنامج المناسب لك وابدأ رحلة التحول اليوم"
                : "Choose the right program for you and start your transformation today")
        </p>
    </div>

    @{
        var privatePrograms = Model.Where(p => p.Slug.StartsWith("private-", StringComparison.OrdinalIgnoreCase)).ToList();
        var normalPrograms = Model.Where(p => !p.Slug.StartsWith("private-", StringComparison.OrdinalIgnoreCase)).ToList();
    }

    <!-- ═══════════ TRAINING PROGRAMS (Normal) ═══════════ -->
    @if (normalPrograms.Any())
    {
        <div class="mb-20">
            <h2 class="text-2xl sm:text-3xl font-extrabold mb-8 flex items-center gap-3">
                <span class="w-2 h-8 bg-brand-600 rounded-full"></span>
                @(isArabic ? "برامج التدريب الجاهزة" : "Ready-to-Use Programs")
            </h2>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var program in normalPrograms)
                {
                    <div class="bg-dark-900/50 border border-white/5 rounded-2xl overflow-hidden hover:border-brand-500/20 transition-all group hover:-translate-y-1 duration-300">
                        <!-- Cover Image -->
                        <div class="aspect-video bg-dark-800 relative overflow-hidden">
                            @if (!string.IsNullOrEmpty(program.CoverImageUrl))
                            {
                                <img src="@program.CoverImageUrl" alt="@(isArabic ? program.TitleAr : program.TitleEn)"
                                     class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" />
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center">
                                    <svg class="w-16 h-16 text-dark-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                </div>
                            }

                            @if (program.IsFeatured)
                            {
                                <div class="absolute top-3 start-3 px-3 py-1 rounded-full bg-brand-600 text-white text-xs font-semibold">
                                    @(isArabic ? "مميز" : "Featured")
                                </div>
                            }
                        </div>

                        <!-- Content -->
                        <div class="p-6">
                            <h3 class="text-xl font-bold mb-2 group-hover:text-brand-400 transition-colors">
                                @(isArabic ? program.TitleAr : program.TitleEn)
                            </h3>
                            <p class="text-dark-400 text-sm mb-4 line-clamp-2">
                                @(isArabic ? program.DescriptionAr : program.DescriptionEn)
                            </p>

                            <!-- Price -->
                            <div class="flex items-center gap-3 mb-5">
                                <span class="text-2xl font-extrabold text-brand-400">
                                    @program.Price.ToString("N0") @(isArabic ? "ج.م" : "EGP")
                                </span>
                                @if (program.CompareAtPrice.HasValue && program.CompareAtPrice > program.Price)
                                {
                                    <span class="text-dark-500 line-through text-sm">
                                        @program.CompareAtPrice.Value.ToString("N0") @(isArabic ? "ج.م" : "EGP")
                                    </span>
                                }
                            </div>

                            <a href="@Url.Action("Details", "Programs", new { slug = program.Slug })"
                               class="block w-full text-center py-3 rounded-xl bg-dark-800 hover:bg-dark-700 border border-white/5 text-white font-semibold transition-all">
                                @(isArabic ? "عرض التفاصيل" : "View Details")
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- ═══════════ PRIVATE TRAINING SECTION ═══════════ -->
    @if (privatePrograms.Any())
    {
        <div class="relative py-12 px-6 sm:px-10 rounded-[2.5rem] overflow-hidden border border-amber-500/20 bg-gradient-to-br from-amber-500/5 via-transparent to-orange-500/5">
            <div class="absolute top-0 right-0 p-10 opacity-[0.03] transform translate-x-10 -translate-y-10">
                <svg class="w-64 h-64" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L1 21h22L12 2zm0 3.45L20.22 19H3.78L12 5.45zM11 11h2v5h-2v-5zm0-4h2v2h-2V7z"/></svg>
            </div>

            <div class="relative mb-12">
                <h2 class="text-3xl sm:text-4xl font-black mb-4">
                    @(isArabic ? "التدريب الخاص المباشر" : "Direct Private Training")
                </h2>
                <p class="text-amber-500/80 font-bold tracking-widest uppercase text-sm">
                    @(isArabic ? "تجربة مخصصة 100% لك وحدك" : "100% Personalized Experience")
                </p>
            </div>

            <div class="grid lg:grid-cols-2 gap-10">
                @foreach (var program in privatePrograms)
                {
                    <div class="flex flex-col md:flex-row bg-dark-900/80 backdrop-blur-md rounded-3xl border border-white/10 overflow-hidden group hover:border-amber-500/40 transition-all duration-500 shadow-2xl">
                        <!-- Image -->
                        <div class="w-full md:w-2/5 aspect-square relative overflow-hidden">
                            <img src="@program.CoverImageUrl" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                            <div class="absolute inset-0 bg-gradient-to-t from-dark-950 via-transparent to-transparent opacity-60"></div>
                            
                            <div class="absolute bottom-4 left-4 right-4">
                                <div class="px-3 py-1 bg-amber-500 text-white text-[10px] font-black tracking-widest rounded-full w-fit uppercase">
                                    PRIVATE VIP
                                </div>
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="w-full md:w-3/5 p-8 flex flex-col justify-between">
                            <div>
                                <h3 class="text-2xl font-black text-white mb-3 group-hover:text-amber-400 transition-colors">
                                    @(isArabic ? program.TitleAr : program.TitleEn)
                                </h3>
                                <p class="text-dark-400 text-sm leading-relaxed mb-6">
                                    @(isArabic ? program.DescriptionAr : program.DescriptionEn)
                                </p>
                            </div>

                            <div class="space-y-6">
                                <div class="flex items-center gap-4">
                                    <div class="text-3xl font-black text-amber-500">
                                        @program.Price.ToString("N0") <span class="text-sm font-normal opacity-60">@(isArabic ? "ج.م" : "EGP")</span>
                                    </div>
                                    @if(program.CompareAtPrice > program.Price) {
                                        <div class="text-dark-600 line-through text-sm">@program.CompareAtPrice.Value.ToString("N0")</div>
                                    }
                                </div>

                                <a href="@Url.Action("Details", "Programs", new { slug = program.Slug })"
                                   class="inline-flex items-center justify-center gap-2 w-full py-4 rounded-xl bg-gradient-to-r from-amber-500 to-orange-500 text-white font-bold transition-all hover:shadow-lg hover:shadow-amber-500/20 active:scale-[0.98]">
                                    @(isArabic ? "ابدأ التدريب الخاص" : "Start Private Training")
                                    <svg class="w-5 h-5 @(isArabic ? "rotate-180" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-20">
            <p class="text-dark-500 text-lg">@(isArabic ? "لا توجد برامج متاحة حالياً" : "No programs available at the moment")</p>
        </div>
    }
</section>
