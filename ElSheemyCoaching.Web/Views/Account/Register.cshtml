@model ElSheemyCoaching.Core.DTOs.RegisterViewModel
@using Microsoft.AspNetCore.Localization
@{
    ViewData["Title"] = "إنشاء حساب";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isArabic = requestCulture?.RequestCulture.Culture.Name.StartsWith("ar") ?? true;
}

<section class="min-h-[70vh] flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">
        <div class="bg-dark-900/50 border border-white/5 rounded-2xl p-8">
            <div class="text-center mb-8">
                <h1 class="text-2xl font-extrabold mb-2">@(isArabic ? "إنشاء حساب" : "Create Account")</h1>
                <p class="text-dark-400">@(isArabic ? "أنشئ حسابك للبدء في التسوق" : "Create your account to start shopping")</p>
            </div>

            <form asp-action="Register" asp-controller="Account" method="post" class="space-y-5">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-red-400 text-sm bg-red-500/10 border border-red-500/20 rounded-lg p-3"></div>

                <div>
                    <label asp-for="FullName" class="block text-sm font-medium text-dark-300 mb-1.5"></label>
                    <input asp-for="FullName"
                           class="w-full px-4 py-3 rounded-xl bg-dark-800 border border-white/5 text-white placeholder-dark-500 focus:outline-none focus:border-brand-500/40 focus:ring-1 focus:ring-brand-500/20 transition-all"
                           placeholder="@(isArabic ? "محمد أحمد" : "Mohamed Ahmed")" />
                    <span asp-validation-for="FullName" class="text-red-400 text-xs mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-dark-300 mb-1.5"></label>
                    <input asp-for="Email" type="email"
                           class="w-full px-4 py-3 rounded-xl bg-dark-800 border border-white/5 text-white placeholder-dark-500 focus:outline-none focus:border-brand-500/40 focus:ring-1 focus:ring-brand-500/20 transition-all"
                           placeholder="example@email.com" />
                    <span asp-validation-for="Email" class="text-red-400 text-xs mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="PhoneNumber" class="block text-sm font-medium text-dark-300 mb-1.5"></label>
                    <input asp-for="PhoneNumber" type="tel"
                           class="w-full px-4 py-3 rounded-xl bg-dark-800 border border-white/5 text-white placeholder-dark-500 focus:outline-none focus:border-brand-500/40 focus:ring-1 focus:ring-brand-500/20 transition-all"
                           placeholder="01xxxxxxxxx" dir="ltr" />
                    <span asp-validation-for="PhoneNumber" class="text-red-400 text-xs mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Password" class="block text-sm font-medium text-dark-300 mb-1.5"></label>
                    <input asp-for="Password" type="password"
                           class="w-full px-4 py-3 rounded-xl bg-dark-800 border border-white/5 text-white placeholder-dark-500 focus:outline-none focus:border-brand-500/40 focus:ring-1 focus:ring-brand-500/20 transition-all"
                           placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-red-400 text-xs mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="ConfirmPassword" class="block text-sm font-medium text-dark-300 mb-1.5"></label>
                    <input asp-for="ConfirmPassword" type="password"
                           class="w-full px-4 py-3 rounded-xl bg-dark-800 border border-white/5 text-white placeholder-dark-500 focus:outline-none focus:border-brand-500/40 focus:ring-1 focus:ring-brand-500/20 transition-all"
                           placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-red-400 text-xs mt-1 block"></span>
                </div>

                <button type="submit"
                        class="w-full py-3.5 rounded-xl bg-gradient-to-r from-brand-600 to-brand-500 hover:from-brand-500 hover:to-brand-400 text-white font-semibold transition-all">
                    @(isArabic ? "إنشاء الحساب" : "Create Account")
                </button>
            </form>

            <p class="text-center text-dark-400 text-sm mt-6">
                @(isArabic ? "لديك حساب بالفعل؟" : "Already have an account?")
                <a href="@Url.Action("Login", "Account")" class="text-brand-400 hover:text-brand-300 font-medium">
                    @(isArabic ? "تسجيل الدخول" : "Sign In")
                </a>
            </p>
        </div>
    </div>
</section>
