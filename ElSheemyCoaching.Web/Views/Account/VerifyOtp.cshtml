@model ElSheemyCoaching.Core.DTOs.VerifyOtpViewModel
@{
    ViewData["Title"] = "التحقق من البريد الإلكتروني";
}

<div class="flex-1 flex items-center justify-center px-4 py-12">
    <div class="max-w-md w-full" x-data="otpForm()">
        <div class="bg-dark-900/50 backdrop-blur-xl border border-white/5 rounded-3xl p-8 shadow-2xl">
            <!-- Header -->
            <div class="text-center mb-10">
                <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-brand-500/10 text-brand-500 mb-6 border border-brand-500/20 shadow-lg shadow-brand-500/10">
                    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 19v-8.93a2 2 0 01.89-1.664l7-4.666a2 2 0 012.22 0l7 4.666A2 2 0 0121 10.07V19M3 19a2 2 0 002 2h14a2 2 0 002-2M3 19l6.75-4.5M21 19l-6.75-4.5M3 10l6.75 4.5M21 10l-6.75 4.5m0 0l-1.14.76a2 2 0 01-2.22 0l-1.14-.76" />
                    </svg>
                </div>
                <h1 class="text-3xl font-bold text-white mb-2 font-cairo">تحقق من حسابك</h1>
                <p class="text-dark-400 font-cairo">أدخل الرمز المكون من 6 أرقام المرسل إلى بريدك</p>
            </div>

            <!-- Form -->
            <form asp-action="VerifyOtp" method="post" @@submit="combineOtp">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="Otp" x-model="fullOtp" />

                <div asp-validation-summary="ModelOnly" class="bg-red-500/10 border border-red-500/20 text-red-400 px-4 py-2 rounded-xl text-sm mb-6 text-center font-cairo"></div>

                <!-- OTP Input Boxes -->
                <div class="grid grid-cols-6 gap-3 mb-8" dir="ltr">
                    <template x-for="(digit, index) in pins" :key="index">
                        <input 
                            type="text" 
                            maxlength="1" 
                            x-model="pins[index]"
                            @@input="handleInput($event, index)"
                            @@keydown.backspace="handleBackspace($event, index)"
                            @@paste="handlePaste($event)"
                            :id="'pin-' + index"
                            class="w-full aspect-square text-center text-2xl font-bold bg-dark-800 border-2 border-white/5 rounded-xl focus:border-brand-500 focus:ring-0 text-white transition-all outline-none"
                            placeholder="-"
                        />
                    </template>
                </div>

                <div class="space-y-4">
                    <button type="submit" 
                            class="w-full py-4 px-6 rounded-2xl bg-brand-600 hover:bg-brand-500 text-white font-bold text-lg shadow-lg shadow-brand-600/20 transition-all hover:-translate-y-0.5 active:translate-y-0 font-cairo flex items-center justify-center gap-2">
                        <span>تأكيد الرمز</span>
                        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                    </button>

                    <div class="text-center">
                        <p class="text-dark-400 text-sm font-cairo">
                            لم يصلك الرمز؟ 
                            <a href="#" class="text-brand-400 hover:text-brand-300 transition-colors font-medium">إعادة الإرسال</a>
                        </p>
                    </div>
                </div>
            </form>
        </div>

        <div class="mt-8 text-center">
            <a asp-action="Register" class="text-dark-400 hover:text-white transition-colors text-sm flex items-center justify-center gap-2 font-cairo">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                العودة لإنشاء حساب جديد
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function otpForm() {
            return {
                pins: ['', '', '', '', '', ''],
                fullOtp: '',
                
                handleInput(e, index) {
                    const val = e.target.value;
                    if (!/^\d*$/.test(val)) {
                        this.pins[index] = '';
                        return;
                    }
                    
                    if (val.length >= 1 && index < 5) {
                        document.getElementById('pin-' + (index + 1)).focus();
                    }
                    this.combineOtp();
                },
                
                handleBackspace(e, index) {
                    if (e.target.value === '' && index > 0) {
                        document.getElementById('pin-' + (index - 1)).focus();
                    }
                    this.combineOtp();
                },

                handlePaste(e) {
                    e.preventDefault();
                    const text = e.clipboardData.getData('text').slice(0, 6);
                    if (!/^\d+$/.test(text)) return;
                    
                    text.split('').forEach((char, i) => {
                        this.pins[i] = char;
                    });
                    this.combineOtp();
                },
                
                combineOtp() {
                    this.fullOtp = this.pins.join('');
                }
            }
        }
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    /* Prevent number arrows */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    input[type=number] {
        -moz-appearance: textfield;
    }
</style>
