@model IEnumerable<ElSheemyCoaching.Core.Entities.Order>
@using Microsoft.AspNetCore.Localization
@{
    ViewData["Title"] = "برامجي التدريبية";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isArabic = requestCulture?.RequestCulture.Culture.Name.StartsWith("ar") ?? true;
}

<section class="max-w-7xl mx-auto px-4 py-20 pb-40">
    <div class="mb-12">
        <h1 class="text-3xl font-extrabold mb-2">@(isArabic ? "برامجي التدريبية" : "My Programs")</h1>
        <p class="text-dark-400">@(isArabic ? "قائمة بجميع البرامج التي قمت بشرائها. يمكنك تحميل الملفات من هنا." : "A list of all your purchased programs. You can download the files here.")</p>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-dark-800/50 border border-white/5 rounded-3xl p-12 text-center text-dark-400">
            <svg class="w-16 h-16 mx-auto mb-4 text-dark-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" /></svg>
            <p>@(isArabic ? "لم تقم بشراء أي برامج تدريبية بعد." : "You haven't purchased any training programs yet.")</p>
            <a href="@Url.Action("Index", "Programs")" class="mt-4 inline-block px-6 py-2 bg-brand-600 hover:bg-brand-700 text-white rounded-lg transition-all">
                @(isArabic ? "تصفح البرامج" : "Browse Programs")
            </a>
        </div>
    }
    else
    {
        <div class="space-y-8">
            @foreach (var order in Model)
            {
                <div class="bg-dark-900/50 border border-white/5 rounded-2xl overflow-hidden shadow-xl">
                    <div class="bg-dark-800/80 px-6 py-4 border-b border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
                        <div>
                            <span class="text-sm font-medium text-dark-400">@(isArabic ? "طلب رقم:" : "Order #:")</span>
                            <span class="text-lg font-bold text-white ml-2 rtl:mr-2">@order.OrderNumber</span>
                        </div>
                        <div class="text-sm text-dark-400">
                            @order.CreatedAt.ToString("MMM dd, yyyy")
                        </div>
                    </div>

                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                            @foreach (var item in order.Items)
                            {
                                var program = item.Program;
                                var tokenObj = order.DownloadTokens.FirstOrDefault(t => t.ProgramId == program.Id);

                                <div class="group bg-dark-800 border border-white/5 rounded-xl overflow-hidden flex flex-col hover:border-brand-500/30 transition-all">
                                    <div class="h-40 overflow-hidden relative">
                                        @if (!string.IsNullOrEmpty(program.CoverImageUrl))
                                        {
                                            <img src="@program.CoverImageUrl" alt="@program.TitleEn" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                                        }
                                        else
                                        {
                                            <div class="w-full h-full bg-dark-700 flex items-center justify-center">
                                                <svg class="w-10 h-10 text-dark-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                                            </div>
                                        }
                                        @if (program.IsDeleted)
                                        {
                                            <div class="absolute top-2 right-2 bg-red-600/90 text-white text-xs px-2 py-1 rounded backdrop-blur-sm shadow">
                                                @(isArabic ? "مؤرشف" : "Archived")
                                            </div>
                                        }
                                    </div>
                                    <div class="p-4 flex-1 flex flex-col justify-between space-y-4">
                                        <h3 class="font-bold text-white leading-tight">@(isArabic ? program.TitleAr : program.TitleEn)</h3>
                                        
                                        @if (tokenObj != null)
                                        {
                                            <a href="@Url.Action("Download", "Downloads", new { token = tokenObj.Token })" target="_blank" class="w-full py-2.5 px-4 bg-brand-600 hover:bg-brand-500 text-white rounded-lg flex items-center justify-center gap-2 transition-all font-medium text-sm">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                                                @(isArabic ? "تحميل الملف" : "Download PDF")
                                            </a>
                                        }
                                        else
                                        {
                                            <button disabled class="w-full py-2.5 px-4 bg-dark-700 text-dark-400 rounded-lg cursor-not-allowed text-sm">
                                                @(isArabic ? "الرابط غير متاح" : "Link unavailable")
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>
