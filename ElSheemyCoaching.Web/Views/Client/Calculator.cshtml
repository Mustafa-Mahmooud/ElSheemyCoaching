@{
    ViewData["Title"] = "Calorie Calculator";
    var isArabic = System.Globalization.CultureInfo.CurrentCulture.Name.StartsWith("ar");
}

<div class="max-w-4xl mx-auto px-4 py-12" x-data="calorieCalculator()">
    <!-- Header -->
    <div class="bg-brand-600 rounded-t-2xl py-6 shadow-xl text-center border-b border-white/10">
        <h1 class="text-3xl font-bold text-white tracking-wide">
            @(isArabic ? "حاسبة السعرات الحرارية" : "Calorie Calculator")
        </h1>
    </div>

    <!-- Main Content -->
    <div class="bg-dark-900 rounded-b-2xl shadow-2xl overflow-hidden border border-white/5">
        <div class="p-8 md:p-12">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <!-- Left Column: Inputs -->
                <div class="space-y-6">
                    <!-- HEIGHT -->
                    <div class="flex items-center gap-4 group">
                        <label class="w-24 text-sm font-semibold text-dark-400 group-hover:text-white transition-colors">
                            @(isArabic ? "الطول" : "HEIGHT")
                        </label>
                        <div class="flex-1 relative">
                            <input type="number" x-model.number="height" 
                                   class="w-full bg-dark-800 border border-white/10 rounded-lg px-4 py-3 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-all outline-none"
                                   placeholder="cm">
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-dark-500">cm</span>
                        </div>
                    </div>

                    <!-- AGE -->
                    <div class="flex items-center gap-4 group">
                        <label class="w-24 text-sm font-semibold text-dark-400 group-hover:text-white transition-colors">
                            @(isArabic ? "العمر" : "AGE")
                        </label>
                        <div class="flex-1 relative">
                            <input type="number" x-model.number="age" 
                                   class="w-full bg-dark-800 border border-white/10 rounded-lg px-4 py-3 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-all outline-none"
                                   placeholder="yrs">
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-dark-500">yrs</span>
                        </div>
                    </div>

                    <!-- WEIGHT -->
                    <div class="flex items-center gap-4 group">
                        <label class="w-24 text-sm font-semibold text-dark-400 group-hover:text-white transition-colors">
                            @(isArabic ? "الوزن" : "WEIGHT")
                        </label>
                        <div class="flex-1 relative">
                            <input type="number" x-model.number="weight" 
                                   class="w-full bg-dark-800 border border-white/10 rounded-lg px-4 py-3 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-all outline-none"
                                   placeholder="kg">
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-dark-500">kg</span>
                        </div>
                    </div>

                    <!-- ACTIVITY -->
                    <div class="flex items-center gap-4 group">
                        <label class="w-24 text-sm font-semibold text-dark-400 group-hover:text-white transition-colors">
                            @(isArabic ? "النشاط" : "ACTIVITY")
                        </label>
                        <select x-model="activity" 
                                class="flex-1 bg-dark-800 border border-white/10 rounded-lg px-4 py-3 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-all outline-none">
                            <option value="1.2">@(isArabic ? "خامل (جلوس دائم)" : "Sedentary")</option>
                            <option value="1.375">@(isArabic ? "نشاط خفيف (تمارين 1-3 أيام)" : "Lightly Active")</option>
                            <option value="1.55">@(isArabic ? "نشاط متوسط (تمارين 3-5 أيام)" : "Moderately Active")</option>
                            <option value="1.725">@(isArabic ? "نشاط عالي (تمارين 6-7 أيام)" : "Very Active")</option>
                            <option value="1.9">@(isArabic ? "نشاط فائق (عمل بدني شاق)" : "Extra Active")</option>
                        </select>
                    </div>

                    <!-- GOAL -->
                    <div class="flex items-center gap-4 group">
                        <label class="w-24 text-sm font-semibold text-dark-400 group-hover:text-white transition-colors">
                            @(isArabic ? "الهدف" : "GOAL")
                        </label>
                        <select x-model="goal" 
                                class="flex-1 bg-dark-800 border border-white/10 rounded-lg px-4 py-3 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-all outline-none">
                            <option value="0">@(isArabic ? "محافظة على الوزن" : "Maintain Weight")</option>
                            <option value="-250">@(isArabic ? "فقدان وزن طفيف (0.25 كجم/أسبوع)" : "Mild Loss (0.25 kg/week)")</option>
                            <option value="-500">@(isArabic ? "فقدان وزن (0.5 كجم/أسبوع)" : "Weight Loss (0.5 kg/week)")</option>
                            <option value="-1000">@(isArabic ? "فقدان وزن حاد (1 كجم/أسبوع)" : "Extreme Loss (1 kg/week)")</option>
                            <option value="250">@(isArabic ? "زيادة وزن طفيفة (0.25 كجم/أسبوع)" : "Mild Gain (0.25 kg/week)")</option>
                            <option value="500">@(isArabic ? "زيادة وزن (0.5 كجم/أسبوع)" : "Weight Gain (0.5 kg/week)")</option>
                        </select>
                    </div>
                </div>

                <!-- Right Column: Formulas & Results -->
                <div class="space-y-8">
                    <!-- Gender Toggle -->
                    <div class="flex items-center justify-between bg-dark-800/50 p-4 rounded-xl border border-white/5">
                        <label class="flex items-center gap-3 cursor-pointer group">
                             <input type="radio" value="male" x-model="gender" class="hidden">
                             <div class="w-12 h-6 flex items-center bg-dark-700 rounded-full p-1 transition-all duration-300"
                                  :class="gender === 'male' ? 'bg-brand-600' : 'bg-dark-700'">
                                 <div class="bg-white w-4 h-4 rounded-full shadow-md transform transition-transform duration-300"
                                      :class="gender === 'male' ? 'translate-x-6' : 'translate-x-0'"></div>
                             </div>
                             <span class="text-xs font-bold uppercase tracking-widest" :class="gender === 'male' ? 'text-white' : 'text-dark-500'">MALE</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                             <input type="radio" value="female" x-model="gender" class="hidden">
                             <div class="w-12 h-6 flex items-center bg-dark-700 rounded-full p-1 transition-all duration-300"
                                  :class="gender === 'female' ? 'bg-brand-600' : 'bg-dark-700'">
                                 <div class="bg-white w-4 h-4 rounded-full shadow-md transform transition-transform duration-300"
                                      :class="gender === 'female' ? 'translate-x-6' : 'translate-x-0'"></div>
                             </div>
                             <span class="text-xs font-bold uppercase tracking-widest" :class="gender === 'female' ? 'text-white' : 'text-dark-500'">FEMALE</span>
                        </label>
                    </div>

                    <!-- Formulas -->
                    <div class="space-y-4">
                        <h3 class="text-lg font-bold text-dark-200 border-b border-white/5 pb-2">
                             @(isArabic ? "معدل الأيض الأساسي (BMR)" : "BASAL METABOLIC RATE")
                        </h3>
                        
                        <div class="space-y-3">
                            <template x-for="formula in formulas">
                                <div class="flex items-center justify-between group">
                                    <div class="flex items-center gap-3">
                                        <button @@click="toggleFormula(formula.id)" 
                                                class="w-10 h-5 flex items-center rounded-full p-1 transition-all duration-300"
                                                :class="selectedFormula === formula.id ? 'bg-brand-600' : 'bg-dark-800 border border-white/10'">
                                            <div class="bg-white w-3 h-3 rounded-full transform transition-transform duration-300"
                                                 :class="selectedFormula === formula.id ? 'translate-x-5' : 'translate-x-0'"></div>
                                        </button>
                                        <span class="text-xs font-medium text-dark-400 group-hover:text-white transition-colors" x-text="formula.name"></span>
                                    </div>
                                    <span class="text-sm font-mono text-brand-400" x-text="getBmrResult(formula.id)"></span>
                                </div>
                            </template>
                        </div>
                    </div>

                    <!-- Final Result -->
                    <div class="bg-gradient-to-br from-brand-600/20 to-brand-900/40 p-6 rounded-2xl border border-brand-500/20 shadow-inner">
                        <div class="text-center">
                            <span class="text-xs font-bold text-brand-400 uppercase tracking-widest mb-2 block">
                                @(isArabic ? "احتياجك اليومي المقترح" : "DAILY CALORIE GOAL")
                            </span>
                            <div class="text-5xl font-black text-white mb-1" x-text="calculateTotal()">2500</div>
                            <span class="text-sm text-dark-400">kcal / day</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Info Footer -->
    <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-dark-900/50 p-6 rounded-xl border border-white/5 hover:border-brand-500/30 transition-all">
            <h4 class="text-brand-400 font-bold mb-2">BMR</h4>
            <p class="text-sm text-dark-400">@(isArabic ? "السعرات التي يحرقها جسمك في وضع الراحة تماماً." : "Calories burned at complete rest.")</p>
        </div>
        <div class="bg-dark-900/50 p-6 rounded-xl border border-white/5 hover:border-brand-500/30 transition-all">
            <h4 class="text-brand-400 font-bold mb-2">TDEE</h4>
            <p class="text-sm text-dark-400">@(isArabic ? "إجمالي الطاقة المستهلكة يومياً مع احتساب النشاط." : "Total energy expenditure including physical activity.")</p>
        </div>
        <div class="bg-dark-900/50 p-6 rounded-xl border border-white/5 hover:border-brand-500/30 transition-all">
            <h4 class="text-brand-400 font-bold mb-2">Macro Suggestion</h4>
            <p class="text-sm text-dark-400">@(isArabic ? "لأفضل النتائج، استشر مدربك لتوزيع البروتين والدهون والكربوهيدرات." : "For best results, consult your coach for macro distribution.")</p>
        </div>
    </div>
</div>

<script>
function calorieCalculator() {
    return {
        height: 170,
        age: 25,
        weight: 70,
        gender: 'male',
        activity: 1.2,
        goal: 0,
        selectedFormula: 'mifflin',
        formulas: [
            { id: 'mifflin', name: 'MIFFLIN-ST JEOR FORMULA' },
            { id: 'harris', name: 'HARRIS-BENEDICT (REVISED)' },
            { id: 'who', name: 'WHO FORMULA' },
            { id: 'average', name: 'AVERAGE' }
        ],
        toggleFormula(id) {
            this.selectedFormula = id;
        },
        calculateBmr(id) {
            if (!this.height || !this.weight || !this.age) return 0;
            
            let bmr = 0;
            if (id === 'mifflin') {
                bmr = (10 * this.weight) + (6.25 * this.height) - (5 * this.age);
                bmr += (this.gender === 'male' ? 5 : -161);
            } else if (id === 'harris') {
                if (this.gender === 'male') {
                    bmr = 88.362 + (13.397 * this.weight) + (4.799 * this.height) - (5.677 * this.age);
                } else {
                    bmr = 447.593 + (9.247 * this.weight) + (3.098 * this.height) - (4.330 * this.age);
                }
            } else if (id === 'who') {
                // Simplified WHO formula for adults 18-30 and 31-60
                if (this.age <= 30) {
                    bmr = this.gender === 'male' ? (15.3 * this.weight) + 679 : (14.7 * this.weight) + 496;
                } else {
                    bmr = this.gender === 'male' ? (11.6 * this.weight) + 879 : (8.7 * this.weight) + 829;
                }
            } else if (id === 'average') {
                let m = this.calculateBmr('mifflin');
                let h = this.calculateBmr('harris');
                let w = this.calculateBmr('who');
                bmr = (m + h + w) / 3;
            }
            return Math.round(bmr);
        },
        getBmrResult(id) {
            let res = this.calculateBmr(id);
            return res > 0 ? res : '---';
        },
        calculateTotal() {
            let bmr = this.calculateBmr(this.selectedFormula);
            if (bmr === 0) return '---';
            let tdee = bmr * parseFloat(this.activity);
            let target = tdee + parseInt(this.goal);
            return Math.round(target);
        }
    }
}
</script>
