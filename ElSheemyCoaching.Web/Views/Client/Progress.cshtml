@model IEnumerable<ElSheemyCoaching.Core.Entities.UserProgress>
@using Microsoft.AspNetCore.Localization
@{
    ViewData["Title"] = "تتبع التقدم";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isArabic = requestCulture?.RequestCulture.Culture.Name.StartsWith("ar") ?? true;
}

<section class="max-w-4xl mx-auto px-4 py-20 pb-40">
    <div class="mb-12 text-center">
        <h1 class="text-3xl font-extrabold mb-2">@(isArabic ? "تتبع تقدمك" : "Track Your Progress")</h1>
        <p class="text-dark-400">@(isArabic ? "سجل وزنك وملاحظاتك يومياً للوصول لهدفك." : "Log your weight and notes daily to reach your goal.")</p>
    </div>

    <!-- Add Progress Form -->
    <div class="bg-dark-900/50 border border-white/5 rounded-2xl p-6 md:p-8 mb-12 shadow-xl">
        <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" /></svg>
            @(isArabic ? "سجل بيانات اليوم" : "Log Today's Data")
        </h2>
        
        <form asp-action="LogProgress" asp-controller="Client" method="post" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-medium text-dark-300 mb-2">@(isArabic ? "الوزن (كجم)" : "Weight (kg)")</label>
                    <input type="number" step="0.1" name="weight" required 
                           class="w-full bg-dark-800 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-brand-500 transition-colors"
                           placeholder="75.5" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-dark-300 mb-2">@(isArabic ? "ملاحظات (اختياري)" : "Notes (Optional)")</label>
                    <input type="text" name="notes" 
                           class="w-full bg-dark-800 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-brand-500 transition-colors"
                           placeholder="@(isArabic ? "شربت 3 لتر ماء، أتممت التمرين" : "Drank 3L water, finished workout")" />
                </div>
            </div>
            
            <button type="submit" class="w-full md:w-auto px-8 py-3 bg-brand-600 hover:bg-brand-500 text-white font-bold rounded-xl transition-all shadow-[0_0_20px_rgba(234,88,12,0.3)]">
                @(isArabic ? "حفظ السجل" : "Save Entry")
            </button>
        </form>
    </div>

    <!-- History -->
    <h2 class="text-xl font-bold mb-6">@(isArabic ? "سجلك السابق" : "History")</h2>
    
    @if (!Model.Any())
    {
        <div class="text-center text-dark-400 py-8 bg-dark-800/30 rounded-2xl border border-white/5">
            @(isArabic ? "لم تقم بتسجيل أي بيانات بعد." : "No records found.")
        </div>
    }
    else
    {
        <div class="bg-dark-900/50 border border-white/5 rounded-2xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left rtl:text-right border-collapse">
                    <thead class="bg-dark-800/80 border-b border-white/5">
                        <tr>
                            <th class="px-6 py-4 font-semibold text-dark-300 text-sm">@(isArabic ? "التاريخ" : "Date")</th>
                            <th class="px-6 py-4 font-semibold text-dark-300 text-sm">@(isArabic ? "الوزن" : "Weight")</th>
                            <th class="px-6 py-4 font-semibold text-dark-300 text-sm">@(isArabic ? "الوقت" : "Time")</th>
                            <th class="px-6 py-4 font-semibold text-dark-300 text-sm w-1/2">@(isArabic ? "ملاحظات" : "Notes")</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-dark-800">
                        @foreach (var entry in Model)
                        {
                            <tr class="hover:bg-dark-800/50 transition-colors">
                                <td class="px-6 py-4 text-white font-medium whitespace-nowrap">@entry.Date.ToString("MMM dd, yyyy")</td>
                                <td class="px-6 py-4 font-bold text-brand-400">@entry.Weight kg</td>
                                <td class="px-6 py-4 text-dark-400 text-sm">@entry.CreatedAt.ToString("HH:mm")</td>
                                <td class="px-6 py-4 text-dark-400 text-sm">@(entry.Notes ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
