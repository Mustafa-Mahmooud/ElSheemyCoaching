@using Microsoft.AspNetCore.Localization
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ElSheemyCoaching.Core.Entities.ApplicationUser> SignInManager
@inject UserManager<ElSheemyCoaching.Core.Entities.ApplicationUser> UserManager
@inject ElSheemyCoaching.Data.ApplicationDbContext DbContext
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var culture = requestCulture?.RequestCulture.Culture.Name ?? "ar-EG";
    var isArabic = culture.StartsWith("ar");
    var dir = isArabic ? "rtl" : "ltr";
    var lang = isArabic ? "ar" : "en";
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ElSheemy Coaching</title>

    <!-- Google Fonts: Cairo (Arabic) + Inter (English) + Outfit (Logo) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;500;700;900&display=swap" rel="stylesheet" />

    <!-- Tailwind CSS CDN (v3) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        cairo: ['Cairo', 'sans-serif'],
                        inter: ['Inter', 'sans-serif'],
                        outfit: ['Outfit', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#fdf4f3',
                            100: '#fce8e6',
                            200: '#f9d4d1',
                            300: '#f3b0aa',
                            400: '#ea827a',
                            500: '#dc5a50',
                            600: '#c93d33',
                            700: '#a93028',
                            800: '#8c2b24',
                            900: '#752924',
                            950: '#40120e',
                        },
                        dark: {
                            50: '#f6f6f6',
                            100: '#e7e7e7',
                            200: '#d1d1d1',
                            300: '#b0b0b0',
                            400: '#888888',
                            500: '#6d6d6d',
                            600: '#5d5d5d',
                            700: '#4f4f4f',
                            800: '#454545',
                            900: '#1a1a2e',
                            950: '#0f0f1a',
                        }
                    }
                }
            }
        }
    </script>

    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <style>
        body {
            font-family: '@(isArabic ? "Cairo" : "Inter")', sans-serif;
        }
        [dir="rtl"] body {
            font-family: 'Cairo', sans-serif;
        }
        [dir="ltr"] body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>
<body class="bg-dark-950 text-white min-h-screen flex flex-col">

    <!-- ═══════════ NAVBAR ═══════════ -->
    <nav class="bg-dark-900/80 backdrop-blur-md border-b border-white/5 sticky top-0 z-50" x-data="{ mobileOpen: false }">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-2 md:grid-cols-3 items-center h-16">
                <!-- Left Nav (Desktop) -->
                <div class="hidden md:flex items-center gap-6">
                    <a href="@Url.Action("Index", "Programs")" class="text-dark-300 hover:text-white transition-colors text-sm font-medium">
                        @(isArabic ? "البرامج" : "Programs")
                    </a>
                    <a href="@Url.Action("Calculator", "Client")" class="text-dark-300 hover:text-white transition-colors text-sm font-medium">
                        @(isArabic ? "الحاسبة" : "Calculator")
                    </a>
                    <a href="@Url.Action("Alternatives", "Foods")" class="text-dark-300 hover:text-white transition-colors text-sm font-medium">
                        @(isArabic ? "البدائل" : "Alternatives")
                    </a>
                </div>

                <!-- Cultural-Aware Logo (Center) -->
                <div class="flex justify-start md:justify-center">
                    <a href="/" class="group flex flex-col items-center leading-none py-2 relative select-none transform transition-transform hover:scale-105">
                        <div class="flex items-center justify-center scale-[0.65] sm:scale-75 md:scale-90 lg:scale-100 origin-right md:origin-center">
                            @if (isArabic)
                            {
                                <!-- Arabic Logo -->
                                <div class="relative flex flex-col items-center justify-center shrink-0" style="width: 220px; height: 60px;">
                                    <svg width="100%" viewBox="0 0 440 160" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <defs>
                                            <style>
                                                @@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@800&display=swap');
                                            </style>
                                            <linearGradient id="logoGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                                                <stop offset="0%" stop-color="#ffffff" />
                                                <stop offset="70%" stop-color="#f59e0b" />
                                            </linearGradient>
                                        </defs>

                                        <!-- Arabic name with Dr. -->
                                        <text x="220" y="80"
                                              text-anchor="middle"
                                              font-family="'Cairo', sans-serif"
                                              font-size="76"
                                              font-weight="800"
                                              fill="url(#logoGradient)">د. الشيمي</text>

                                      
                                    </svg>
                                </div>
                            }
                            else
                            {
                                <!-- English Logo -->
                                <div class="relative flex flex-col items-center justify-center" style="width: 220px; height: 60px;">
                                    <svg width="100%" viewBox="0 0 480 160" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <defs>
                                            <style>
                                                @@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap');
                                            </style>
                                            <linearGradient id="enLogoGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                                                <stop offset="0%" stop-color="#f97316" />
                                                <stop offset="40%" stop-color="#ffffff" />
                                            </linearGradient>
                                        </defs>

                                        <!-- DR. ELSHEMY -->
                                        <text x="240" y="90"
                                              text-anchor="middle"
                                              font-family="'Bebas Neue', 'Arial Narrow', sans-serif"
                                              font-size="86"
                                              letter-spacing="8"
                                              fill="url(#enLogoGradient)">DR. ELSHEMY</text>

                                       
                                    </svg>
                                </div>
                            }
                        </div>
                    </a>
                </div>

                <!-- Right Nav (Desktop) -->
                <div class="hidden md:flex items-center justify-end gap-5">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        var userId = UserManager.GetUserId(User);
                        var unreadCount = DbContext.InAppNotifications.Count(n => n.UserId == userId && !n.IsRead);

                        <div class="flex items-center gap-4">
                             @if (User.IsInRole("Admin") || User.IsInRole("Coach"))
                             {
                                <div class="relative group" x-data="{ open: false }">
                                    <button @@click="open = !open" @@click.away="open = false" 
                                            class="flex items-center gap-1 text-amber-500 hover:text-amber-400 transition-all font-bold text-sm bg-amber-500/10 px-3 py-1.5 rounded-lg border border-amber-500/20">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                                        <span>@(isArabic ? "الإدارة" : "Admin")</span>
                                        <svg class="w-3 h-3 transition-transform duration-200" :class="{'rotate-180': open}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                                    </button>
                                    
                                    <div x-show="open" 
                                         x-transition:enter="transition ease-out duration-100"
                                         x-transition:enter-start="opacity-0 scale-95"
                                         x-transition:enter-end="opacity-100 scale-100"
                                         class="absolute @(isArabic ? "left-0" : "right-0") mt-2 w-52 bg-dark-900 border border-white/10 rounded-xl shadow-2xl z-[100] py-2 overflow-hidden">
                                        
                                        <a href="@Url.Action("Index", "Admin")" class="flex items-center gap-3 px-4 py-2.5 text-sm text-dark-300 hover:bg-amber-500/10 hover:text-amber-400 transition-colors">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                                            @(isArabic ? "لوحة التحكم" : "Dashboard")
                                        </a>
                                        
                                        <a href="@Url.Action("Orders", "Admin")" class="flex items-center gap-3 px-4 py-2.5 text-sm text-dark-300 hover:bg-amber-500/10 hover:text-amber-400 transition-colors">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
                                            @(isArabic ? "الطلبات" : "Orders")
                                        </a>
                                        
                                        <a href="@Url.Action("Programs", "Admin")" class="flex items-center gap-3 px-4 py-2.5 text-sm text-dark-300 hover:bg-amber-500/10 hover:text-amber-400 transition-colors">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                                            @(isArabic ? "إدارة البرامج" : "Manage Programs")
                                        </a>
                                        
                                        <a href="@Url.Action("Transformations", "Admin")" class="flex items-center gap-3 px-4 py-2.5 text-sm text-dark-300 hover:bg-amber-500/10 hover:text-amber-400 transition-colors">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                                            @(isArabic ? "التحولات" : "Transformations")
                                        </a>
                                        
                                        <a href="@Url.Action("Customers", "Admin")" class="flex items-center gap-3 px-4 py-2.5 text-sm text-dark-300 hover:bg-amber-500/10 hover:text-amber-400 transition-colors">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 01-9-3.812" /></svg>
                                            @(isArabic ? "العملاء" : "Customers")
                                        </a>
                                    </div>
                                </div>
                             }
                            
                            <a href="@Url.Action("MyPrograms", "Client")" class="text-dark-300 hover:text-white transition-colors text-sm font-medium">
                                @(isArabic ? "برامجي" : "My Programs")
                            </a>
                            <a href="@Url.Action("Progress", "Client")" class="text-dark-300 hover:text-white transition-colors text-sm font-medium">
                                @(isArabic ? "تقدمي" : "Progress")
                            </a>

                            <a href="@Url.Action("Index", "Notifications")" class="relative text-dark-300 hover:text-white transition-colors" title="@(isArabic ? "الإشعارات" : "Notifications")">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
                                @if(unreadCount > 0) {
                                    <span class="absolute -top-1.5 -right-1.5 flex h-4 w-4 items-center justify-center rounded-full bg-brand-600 text-[10px] font-bold text-white border-2 border-dark-900">@unreadCount</span>
                                }
                            </a>

                            <div class="h-4 w-px bg-white/10 mx-1"></div>

                            <div class="flex items-center gap-3">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="text-dark-400 hover:text-white text-xs font-semibold uppercase tracking-wider transition-colors">
                                        @(isArabic ? "خروج" : "Logout")
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a href="@Url.Action("Login", "Account")" class="text-dark-300 hover:text-white text-sm font-medium">
                            @(isArabic ? "دخول" : "Login")
                        </a>
                        <a href="@Url.Action("Register", "Account")" class="px-4 py-2 rounded-lg bg-brand-600 hover:bg-brand-500 text-white text-xs font-bold transition-all shadow-lg shadow-brand-600/20">
                            @(isArabic ? "ابدأ الآن" : "Start Now")
                        </a>
                    }

                    <!-- Language Switcher -->
                    <form asp-controller="Language" asp-action="Set" method="post" class="inline m-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                        <input type="hidden" name="culture" value="@(isArabic ? "en-US" : "ar-EG")" />
                        <button type="submit" class="w-8 h-8 flex items-center justify-center rounded-full bg-dark-800 hover:bg-dark-700 text-[10px] font-bold text-dark-300 hover:text-white transition-all border border-white/5">
                            @(isArabic ? "EN" : "ع")
                        </button>
                    </form>
                </div>

                <!-- Mobile menu button -->
                <div class="flex justify-end md:hidden">
                    <button @@click="mobileOpen = !mobileOpen" class="text-dark-400 hover:text-white p-2 focus:outline-none">
                        <svg x-show="!mobileOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                        <svg x-show="mobileOpen" x-cloak class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Mobile Nav -->
            <div x-show="mobileOpen" x-transition class="md:hidden pb-6 space-y-4 px-2">
                <!-- Mobile Language Switcher (Prominent) -->
                <div class="pt-2 pb-4 border-b border-white/5 flex items-center justify-between">
                    <span class="text-xs font-bold text-dark-500 uppercase tracking-widest px-1">@(isArabic ? "اللغة" : "Language")</span>
                    <form asp-controller="Language" asp-action="Set" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                        <input type="hidden" name="culture" value="@(isArabic ? "en-US" : "ar-EG")" />
                        <button type="submit" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-dark-800 border border-white/5 text-sm font-bold text-white transition-all active:scale-95">
                            <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 11.37 9.188 16.524 5 20" /></svg>
                            @(isArabic ? "Switch to English" : "تغيير للغة العربية")
                        </button>
                    </form>
                </div>

                <a href="@Url.Action("Index", "Programs")" class="block py-2 px-3 text-dark-300 hover:text-white font-medium flex items-center gap-3">
                    <svg class="w-5 h-5 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                    @(isArabic ? "تصفح البرامج" : "Browse Programs")
                </a>
                @if (SignInManager.IsSignedIn(User))
                {
                    var userId = UserManager.GetUserId(User);
                    var unreadCount = DbContext.InAppNotifications.Count(n => n.UserId == userId && !n.IsRead);

                    @if (User.IsInRole("Admin") || User.IsInRole("Coach"))
                    {
                        <div class="pt-4 pb-2 border-b border-white/5">
                            <p class="px-3 text-[10px] font-bold text-amber-500 uppercase tracking-widest mb-2">@(isArabic ? "لوحة الإدارة" : "Admin Panel")</p>
                            <a href="@Url.Action("Index", "Admin")" class="block py-2 px-3 text-dark-300 hover:text-white flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                                @(isArabic ? "التحليلات" : "Analysis")
                            </a>
                            <a href="@Url.Action("Orders", "Admin")" class="block py-2 px-3 text-dark-300 hover:text-white flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
                                @(isArabic ? "الطلبات" : "Orders")
                            </a>
                            <a href="@Url.Action("Programs", "Admin")" class="block py-2 px-3 text-dark-300 hover:text-white flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                                @(isArabic ? "إدارة البرامج" : "Programs")
                            </a>
                            <a href="@Url.Action("Transformations", "Admin")" class="block py-2 px-3 text-dark-300 hover:text-white flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                                @(isArabic ? "التحولات" : "Transformations")
                            </a>
                            <a href="@Url.Action("Customers", "Admin")" class="block py-2 px-3 text-dark-300 hover:text-white flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 01-9-3.812" /></svg>
                                @(isArabic ? "العملاء" : "Customers")
                            </a>
                        </div>
                    }

                    <div class="space-y-1">
                        <a href="@Url.Action("MyPrograms", "Client")" class="block py-2.5 px-3 rounded-lg text-dark-300 hover:text-white hover:bg-white/5 flex items-center gap-3">
                            <svg class="w-5 h-5 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                            @(isArabic ? "برامجي" : "My Programs")
                        </a>
                        <a href="@Url.Action("Progress", "Client")" class="block py-2.5 px-3 rounded-lg text-dark-300 hover:text-white hover:bg-white/5 flex items-center gap-3">
                            <svg class="w-5 h-5 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                            @(isArabic ? "تقدمي" : "Progress")
                        </a>
                        <a href="@Url.Action("Calculator", "Client")" class="block py-2.5 px-3 rounded-lg text-dark-300 hover:text-white hover:bg-white/5 flex items-center gap-3">
                            <svg class="w-5 h-5 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                            @(isArabic ? "حاسبة السعرات" : "Calculator")
                        </a>
                        <a href="@Url.Action("Alternatives", "Foods")" class="block py-2.5 px-3 rounded-lg text-white font-bold bg-brand-600/10 border-l-2 border-brand-500 pl-3 flex items-center gap-3">
                            <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 15.546c-.523 0-1.046.151-1.5.454a2.704 2.704 0 01-3 0 2.704 2.704 0 01-3 0 2.704 2.704 0 01-3 0 2.704 2.704 0 01-3 0 2.704 2.704 0 01-1.5-.454M9 16v2m3-6v6m3-3v3M9 11V9a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                            @(isArabic ? "بدائل الأطعمة" : "Food Alternatives")
                        </a>
                        <a href="@Url.Action("Index", "Notifications")" class="block py-2.5 px-3 rounded-lg text-dark-300 hover:text-white hover:bg-white/5 flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <svg class="w-5 h-5 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
                                @(isArabic ? "الإشعارات" : "Notifications")
                            </div>
                            @if(unreadCount > 0) {
                                <span class="bg-brand-600 text-white text-[10px] font-bold px-2 py-0.5 rounded-full">@unreadCount</span>
                            }
                        </a>
                    </div>

                    <div class="pt-4 mt-2 border-t border-white/5">
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="w-full flex items-center gap-3 px-3 py-2.5 text-dark-400 hover:text-white transition-colors">
                                <svg class="w-5 h-5 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                                @(isArabic ? "خروج من الحساب" : "Logout")
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="pt-4 space-y-3">
                        <a href="@Url.Action("Login", "Account")" class="block w-full py-4 text-center rounded-xl border border-white/10 text-white font-bold flex items-center justify-center gap-2">
                             <svg class="w-5 h-5 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                            @(isArabic ? "تسجيل الدخول" : "Login")
                        </a>
                        <a href="@Url.Action("Register", "Account")" class="block w-full py-4 text-center rounded-xl bg-brand-600 text-white font-bold shadow-lg shadow-brand-600/20">
                            @(isArabic ? "ابدأ الآن" : "Start Now")
                        </a>
                    </div>
                }
            </div>
        </div>
    </nav>

    <!-- ═══════════ ALERTS ═══════════ -->
    @if (TempData["Success"] is string successMsg)
    {
        <div class="max-w-7xl mx-auto px-4 mt-4" x-data="{ show: true }" x-show="show" x-transition>
            <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 px-4 py-3 rounded-lg flex items-center justify-between">
                <span>@successMsg</span>
                <button @@click="show = false" class="text-emerald-400 hover:text-emerald-300">&times;</button>
            </div>
        </div>
    }

    @if (TempData["Error"] is string errorMsg)
    {
        <div class="max-w-7xl mx-auto px-4 mt-4" x-data="{ show: true }" x-show="show" x-transition>
            <div class="bg-red-500/10 border border-red-500/20 text-red-400 px-4 py-3 rounded-lg flex items-center justify-between">
                <span>@errorMsg</span>
                <button @@click="show = false" class="text-red-400 hover:text-red-300">&times;</button>
            </div>
        </div>
    }

    <!-- ═══════════ MAIN CONTENT ═══════════ -->
    <main class="flex-1">
        @RenderBody()
    </main>

    <!-- ═══════════ FLOATING SOCIAL BUTTONS ═══════════ -->
