@model IEnumerable<ElSheemyCoaching.Core.Entities.Transformation>
@using Microsoft.AspNetCore.Localization
@{
    ViewData["Title"] = "إدارة التحولات";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isArabic = requestCulture?.RequestCulture.Culture.Name.StartsWith("ar") ?? true;
}

<section class="max-w-7xl mx-auto px-4 py-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-2xl font-extrabold mb-1">@(isArabic ? "إدارة التحولات" : "Transformations Management")</h1>
            <p class="text-dark-400 text-sm">@(isArabic ? "إضافة وتعديل صور قبل وبعد للعملاء" : "Add and edit before/after client transformation images")</p>
        </div>
        <a href="@Url.Action("CreateTransformation", "Admin")"
           class="px-5 py-2.5 rounded-xl bg-brand-600 hover:bg-brand-500 text-white font-medium text-sm transition-all flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            @(isArabic ? "إضافة تحول" : "Add Transformation")
        </a>
    </div>

    @await Html.PartialAsync("_AdminNav")

    <!-- Transformations Grid -->
    @if (Model.Any())
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var t in Model)
            {
                <div class="bg-dark-900/50 border border-white/5 rounded-2xl overflow-hidden hover:border-white/10 transition-colors group">
                    <div class="h-48 relative flex">
                        <!-- Before Half -->
                        <div class="w-1/2 h-full relative border-r border-white/10">
                            <img src="@t.BeforeImageUrl" class="w-full h-full object-cover" alt="Before" />
                            <div class="absolute top-2 left-2 px-2 py-0.5 rounded bg-dark-900/80 text-dark-300 text-[10px] font-medium backdrop-blur-sm">
                                BEFORE
                            </div>
                        </div>
                        <!-- After Half -->
                        <div class="w-1/2 h-full relative">
                            <img src="@t.AfterImageUrl" class="w-full h-full object-cover" alt="After" />
                            <div class="absolute top-2 right-2 px-2 py-0.5 rounded bg-brand-600/90 text-white text-[10px] font-bold backdrop-blur-sm">
                                AFTER
                            </div>
                        </div>
                    </div>

                    <div class="p-5">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="font-bold text-white line-clamp-1">@(isArabic ? t.TitleAr : t.TitleEn)</h3>
                            @if (t.IsVisible)
                            {
                                <span class="w-2 h-2 rounded-full bg-emerald-500 shrink-0 mt-1.5 shadow-[0_0_8px_rgba(16,185,129,0.5)]" title="@(isArabic ? "مرئي" : "Visible")"></span>
                            }
                            else
                            {
                                <span class="w-2 h-2 rounded-full bg-dark-600 shrink-0 mt-1.5" title="@(isArabic ? "مخفي" : "Hidden")"></span>
                            }
                        </div>
                        
                        <p class="text-sm text-dark-400 line-clamp-2 mb-4 leading-relaxed h-10">
                            @(isArabic ? t.DescriptionAr : t.DescriptionEn)
                        </p>

                        <div class="flex items-center justify-between pt-4 border-t border-white/5">
                            <div class="text-xs text-dark-500">
                                @(isArabic ? "الترتيب:" : "Order:") <span class="text-white font-mono">@t.DisplayOrder</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <a href="@Url.Action("EditTransformation", "Admin", new { id = t.Id })" class="text-blue-400 hover:bg-blue-500/10 p-1.5 rounded-lg transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                                </a>
                                <form asp-action="DeleteTransformation" asp-route-id="@t.Id" method="post" class="inline" onsubmit="return confirm('@(isArabic ? "هل أنت متأكد من الحذف نهائياً؟" : "Are you sure you want to delete?")')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="text-red-400 hover:bg-red-500/10 p-1.5 rounded-lg transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="bg-dark-900/50 border border-white/5 rounded-2xl p-12 text-center">
            <svg class="w-16 h-16 text-dark-700 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-dark-500 mb-4">@(isArabic ? "لا توجد تحولات، أضف أول تحول لإلهام عملائك!" : "No transformations yet, add one to inspire clients!")</p>
            <a href="@Url.Action("CreateTransformation", "Admin")"
               class="inline-block px-5 py-2.5 rounded-xl bg-brand-600 hover:bg-brand-500 text-white font-medium text-sm transition-all">
                @(isArabic ? "أضف تحول" : "Add Transformation")
            </a>
        </div>
    }
</section>
