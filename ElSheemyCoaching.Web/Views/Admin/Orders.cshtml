@model IEnumerable<ElSheemyCoaching.Core.DTOs.AdminOrderViewModel>
@using Microsoft.AspNetCore.Localization
@using ElSheemyCoaching.Core.Enums
@{
    ViewData["Title"] = "لوحة التحكم - الطلبات";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isArabic = requestCulture?.RequestCulture.Culture.Name.StartsWith("ar") ?? true;
    var currentStatus = ViewBag.CurrentStatus as string ?? "AwaitingVerification";
}

<section class="max-w-7xl mx-auto px-4 py-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-2xl font-extrabold mb-1">@(isArabic ? "إدارة الطلبات" : "Order Management")</h1>
            <p class="text-dark-400 text-sm">@(isArabic ? "مراجعة واعتماد طلبات الدفع" : "Review and approve payment orders")</p>
        </div>
    </div>

    <!-- Admin Nav -->
    <div class="flex gap-2 mb-6">
        <a href="@Url.Action("Orders", "Admin")"
           class="px-4 py-2 rounded-lg text-sm font-medium bg-brand-600/15 text-brand-400 border border-brand-500/20 transition-all">
            @(isArabic ? "الطلبات" : "Orders")
        </a>
        <a href="@Url.Action("Programs", "Admin")"
           class="px-4 py-2 rounded-lg text-sm font-medium bg-dark-800 text-dark-400 hover:text-white border border-white/5 transition-all">
            @(isArabic ? "البرامج" : "Programs")
        </a>
    </div>

    <!-- Status Filter Tabs -->
    <div class="flex gap-2 mb-6 overflow-x-auto pb-2">
        <a href="@Url.Action("Orders", "Admin", new { status = "AwaitingVerification" })"
           class="px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap transition-all @(currentStatus == "AwaitingVerification" ? "bg-amber-500/15 text-amber-400 border border-amber-500/20" : "bg-dark-800 text-dark-400 hover:text-white border border-white/5")">
            @(isArabic ? "في انتظار التأكيد" : "Awaiting Verification")
        </a>
        <a href="@Url.Action("Orders", "Admin", new { status = "Paid" })"
           class="px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap transition-all @(currentStatus == "Paid" ? "bg-emerald-500/15 text-emerald-400 border border-emerald-500/20" : "bg-dark-800 text-dark-400 hover:text-white border border-white/5")">
            @(isArabic ? "مدفوع" : "Paid")
        </a>
        <a href="@Url.Action("Orders", "Admin", new { status = "Cancelled" })"
           class="px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap transition-all @(currentStatus == "Cancelled" ? "bg-red-500/15 text-red-400 border border-red-500/20" : "bg-dark-800 text-dark-400 hover:text-white border border-white/5")">
            @(isArabic ? "ملغي" : "Cancelled")
        </a>
    </div>

    <!-- Orders Table -->
    @if (Model.Any())
    {
        <div class="bg-dark-900/50 border border-white/5 rounded-2xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-white/5 text-dark-400 text-sm">
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "رقم الطلب" : "Order #")</th>
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "العميل" : "Customer")</th>
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "البرامج" : "Programs")</th>
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "المبلغ" : "Amount")</th>
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "التاريخ" : "Date")</th>
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "الإثبات" : "Proof")</th>
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "إجراء" : "Action")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr class="border-b border-white/5 hover:bg-white/[0.02] transition-colors">
                                <td class="px-6 py-4">
                                    <span class="font-mono text-sm font-medium text-brand-400">@order.OrderNumber</span>
                                </td>
                                <td class="px-6 py-4">
                                    <a href="@Url.Action("CustomerDetails", "Admin", new { id = order.UserId })" class="font-medium text-white hover:text-brand-400 transition-colors">@order.CustomerName</a>
                                    <div class="text-dark-500 text-xs mt-0.5">@order.CustomerEmail</div>
                                </td>
                                <td class="px-6 py-4">
                                    @foreach (var item in order.Items)
                                    {
                                        <div class="text-sm">@item.ProgramTitle</div>
                                    }
                                </td>
                                <td class="px-6 py-4 font-bold">@order.Total.ToString("N0") @(isArabic ? "ج.م" : "EGP")</td>
                                <td class="px-6 py-4 text-sm text-dark-400">@order.CreatedAt.ToString("yyyy/MM/dd")</td>
                                <td class="px-6 py-4">
                                    @if (!string.IsNullOrEmpty(order.ProofImagePath))
                                    {
                                        <a href="@Url.Action("ViewProofImage", "Admin", new { path = order.ProofImagePath })"
                                           target="_blank"
                                           class="inline-flex items-center gap-1 text-xs text-brand-400 hover:text-brand-300">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                            </svg>
                                            @(isArabic ? "عرض" : "View")
                                        </a>
                                        @if (!string.IsNullOrEmpty(order.TransactionRef))
                                        {
                                            <div class="text-xs text-dark-500 mt-1" dir="ltr">Ref: @order.TransactionRef</div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-dark-500 text-xs">—</span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    @if (order.Status == OrderStatus.AwaitingVerification && order.PaymentProofId.HasValue)
                                    {
                                        <div class="flex gap-2">
                                            <form asp-controller="Admin" asp-action="ApprovePayment" method="post" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="paymentProofId" value="@order.PaymentProofId" />
                                                <button type="submit"
                                                        class="px-3 py-1.5 rounded-lg text-xs font-medium bg-emerald-500/15 text-emerald-400 hover:bg-emerald-500/25 border border-emerald-500/20 transition-all"
                                                        onclick="return confirm('@(isArabic ? "هل تريد اعتماد هذا الطلب؟" : "Approve this order?")')">
                                                    @(isArabic ? "اعتماد ✓" : "Approve ✓")
                                                </button>
                                            </form>
                                            <form asp-controller="Admin" asp-action="RejectPayment" method="post" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="paymentProofId" value="@order.PaymentProofId" />
                                                <button type="submit"
                                                        class="px-3 py-1.5 rounded-lg text-xs font-medium bg-red-500/15 text-red-400 hover:bg-red-500/25 border border-red-500/20 transition-all"
                                                        onclick="return confirm('@(isArabic ? "هل تريد رفض هذا الطلب؟" : "Reject this order?")')">
                                                    @(isArabic ? "رفض ✗" : "Reject ✗")
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        @if (order.Status == OrderStatus.Paid)
                                        {
                                            <span class="px-3 py-1 rounded-full bg-emerald-500/15 text-emerald-400 text-xs font-medium">
                                                @(isArabic ? "مدفوع" : "Paid")
                                            </span>
                                        }
                                        else if (order.Status == OrderStatus.Cancelled)
                                        {
                                            <span class="px-3 py-1 rounded-full bg-red-500/15 text-red-400 text-xs font-medium">
                                                @(isArabic ? "ملغي" : "Cancelled")
                                            </span>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="bg-dark-900/50 border border-white/5 rounded-2xl p-12 text-center">
            <p class="text-dark-500">@(isArabic ? "لا توجد طلبات في هذا التصنيف" : "No orders in this category")</p>
        </div>
    }
</section>
