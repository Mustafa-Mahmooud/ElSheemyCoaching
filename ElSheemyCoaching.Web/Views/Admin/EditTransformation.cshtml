@model ElSheemyCoaching.Core.DTOs.TransformationFormViewModel
@using Microsoft.AspNetCore.Localization
@{
    ViewData["Title"] = "تعديل تحول";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isArabic = requestCulture?.RequestCulture.Culture.Name.StartsWith("ar") ?? true;
}

<section class="max-w-4xl mx-auto px-4 py-10">
    <div class="mb-8">
        <a href="@Url.Action("Transformations", "Admin")" class="text-dark-400 hover:text-white text-sm flex items-center gap-1 mb-4 transition-colors">
            <svg class="w-4 h-4 @(isArabic ? "rotate-180" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            @(isArabic ? "العودة للتحولات" : "Back to Transformations")
        </a>
        <h1 class="text-2xl font-extrabold">@(isArabic ? "تعديل التحول" : "Edit Transformation")</h1>
    </div>

    <form asp-controller="Admin" asp-action="EditTransformation" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data"
          class="space-y-6" x-data="{ beforePreview: '@(Model.ExistingBeforeImageUrl ?? "")', afterPreview: '@(Model.ExistingAfterImageUrl ?? "")' }">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-red-400 text-sm bg-red-500/10 border border-red-500/20 rounded-lg p-3"></div>

        @await Html.PartialAsync("_TransformationFormFields", Model)

        <button type="submit"
                class="w-full py-3.5 rounded-xl bg-gradient-to-r from-brand-600 to-brand-500 hover:from-brand-500 hover:to-brand-400 text-white font-semibold transition-all text-lg">
            @(isArabic ? "حفظ التعديلات" : "Save Changes")
        </button>
    </form>
</section>
