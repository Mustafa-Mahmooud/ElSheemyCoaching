@model IEnumerable<dynamic>
@using Microsoft.AspNetCore.Localization
@{
    ViewData["Title"] = "العملاء";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isArabic = requestCulture?.RequestCulture.Culture.Name.StartsWith("ar") ?? true;
    var searchQuery = ViewBag.SearchQuery as string;
}

<section class="max-w-7xl mx-auto px-4 py-10">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-extrabold mb-1">@(isArabic ? "إدارة العملاء" : "Customer Management")</h1>
            <p class="text-dark-400 text-sm">@(isArabic ? "عرض تفاصيل العملاء وسجل الشراء" : "View customer details and purchase history")</p>
        </div>
        
        <form method="get" asp-action="Customers" class="relative">
            <input type="text" name="search" value="@searchQuery"
                   placeholder="@(isArabic ? "ابحث بالاسم، الإيميل، رقم الهاتف..." : "Search by name, email, phone...")"
                   class="w-full sm:w-80 px-4 py-2.5 pl-10 bg-dark-800 border border-white/10 rounded-xl text-sm text-white placeholder-dark-500 focus:outline-none focus:border-brand-500/50 focus:ring-1 focus:ring-brand-500/20 transition-all" />
            <svg class="w-4 h-4 text-dark-400 absolute left-3.5 top-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            @if (!string.IsNullOrEmpty(searchQuery))
            {
                <a href="@Url.Action("Customers", "Admin")" class="absolute right-3.5 top-3 text-dark-400 hover:text-white transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </a>
            }
        </form>
    </div>
 
    @await Html.PartialAsync("_AdminNav")

    @if (Model.Any())
    {
        <div class="bg-dark-900/50 border border-white/5 rounded-2xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-white/5 text-dark-400 text-sm">
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "العميل" : "Customer")</th>
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "رقم الهاتف" : "Phone")</th>
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "الطلبات" : "Orders")</th>
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "إجمالي الشراء" : "Total Spent")</th>
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "إجراء" : "Action")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in Model)
                        {
                            <tr class="border-b border-white/5 hover:bg-white/[0.02] transition-colors">
                                <td class="px-6 py-4">
                                    <div class="font-medium text-white">@customer.FullName</div>
                                    <div class="text-dark-500 text-sm">@customer.Email</div>
                                </td>
                                <td class="px-6 py-4 font-mono text-dark-300">
                                    @(string.IsNullOrEmpty(customer.PhoneNumber) ? "—" : customer.PhoneNumber)
                                </td>
                                <td class="px-6 py-4 text-dark-300">
                                    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-dark-800 text-xs font-bold font-mono">
                                        @customer.OrderCount
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="font-bold text-brand-400">@customer.TotalSpent.ToString("N0")</span>
                                    <span class="text-dark-500 text-xs text-brand-500/50">@(isArabic ? "ج.م" : "EGP")</span>
                                </td>
                                <td class="px-6 py-4">
                                    <a href="@Url.Action("CustomerDetails", "Admin", new { id = customer.Id })"
                                       class="px-3 py-1.5 rounded-lg text-xs font-medium bg-blue-500/15 text-blue-400 hover:bg-blue-500/25 border border-blue-500/20 transition-all inline-flex items-center gap-1.5">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                        </svg>
                                        @(isArabic ? "التفاصيل" : "Details")
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="bg-dark-900/50 border border-white/5 rounded-2xl p-12 text-center">
            <p class="text-dark-500 mb-4">@(isArabic ? "لم يتم العثور على عملاء" : "No customers found")</p>
            @if (!string.IsNullOrEmpty(searchQuery))
            {
                <a href="@Url.Action("Customers", "Admin")" class="text-brand-400 hover:text-brand-300 text-sm font-medium">
                    @(isArabic ? "مسح البحث" : "Clear search")
                </a>
            }
        </div>


        @* create a button that gets all customers using the api   consume the API admin Api/Customers*@
          


    }
</section>
