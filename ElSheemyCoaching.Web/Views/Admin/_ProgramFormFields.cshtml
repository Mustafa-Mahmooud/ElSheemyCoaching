@model ElSheemyCoaching.Core.DTOs.ProgramFormViewModel
@using Microsoft.AspNetCore.Localization
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isArabic = requestCulture?.RequestCulture.Culture.Name.StartsWith("ar") ?? true;
}

<!-- Arabic Title -->
<div class="bg-dark-900/50 border border-white/5 rounded-2xl p-6 space-y-5">
    <h2 class="font-bold text-lg border-b border-white/5 pb-3">@(isArabic ? "معلومات البرنامج" : "Program Information")</h2>

    <div class="grid md:grid-cols-2 gap-5">
        <div>
            <label asp-for="TitleAr" class="block text-sm font-medium text-dark-300 mb-1.5"></label>
            <input asp-for="TitleAr"
                   class="w-full px-4 py-3 rounded-xl bg-dark-800 border border-white/5 text-white placeholder-dark-500 focus:outline-none focus:border-brand-500/40 focus:ring-1 focus:ring-brand-500/20 transition-all"
                   placeholder="مثال: برنامج تحول الجسم" />
            <span asp-validation-for="TitleAr" class="text-red-400 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="TitleEn" class="block text-sm font-medium text-dark-300 mb-1.5"></label>
            <input asp-for="TitleEn"
                   class="w-full px-4 py-3 rounded-xl bg-dark-800 border border-white/5 text-white placeholder-dark-500 focus:outline-none focus:border-brand-500/40 focus:ring-1 focus:ring-brand-500/20 transition-all"
                   placeholder="e.g. Body Transformation" dir="ltr" />
            <span asp-validation-for="TitleEn" class="text-red-400 text-xs mt-1 block"></span>
        </div>
    </div>

    <div>
        <label asp-for="Slug" class="block text-sm font-medium text-dark-300 mb-1.5"></label>
        <input asp-for="Slug"
               class="w-full px-4 py-3 rounded-xl bg-dark-800 border border-white/5 text-white placeholder-dark-500 focus:outline-none focus:border-brand-500/40 focus:ring-1 focus:ring-brand-500/20 transition-all font-mono"
               placeholder="body-transformation" dir="ltr" />
        <span asp-validation-for="Slug" class="text-red-400 text-xs mt-1 block"></span>
        <p class="text-dark-500 text-xs mt-1">@(isArabic ? "حروف إنجليزية صغيرة وأرقام وشرطات فقط" : "Lowercase letters, numbers, and hyphens only")</p>
    </div>

    <div>
        <label asp-for="DescriptionAr" class="block text-sm font-medium text-dark-300 mb-1.5"></label>
        <textarea asp-for="DescriptionAr" rows="3"
                  class="w-full px-4 py-3 rounded-xl bg-dark-800 border border-white/5 text-white placeholder-dark-500 focus:outline-none focus:border-brand-500/40 focus:ring-1 focus:ring-brand-500/20 transition-all resize-none"
                  placeholder="وصف البرنامج بالعربية..."></textarea>
    </div>

    <div>
        <label asp-for="DescriptionEn" class="block text-sm font-medium text-dark-300 mb-1.5"></label>
        <textarea asp-for="DescriptionEn" rows="3"
                  class="w-full px-4 py-3 rounded-xl bg-dark-800 border border-white/5 text-white placeholder-dark-500 focus:outline-none focus:border-brand-500/40 focus:ring-1 focus:ring-brand-500/20 transition-all resize-none"
                  placeholder="Program description in English..." dir="ltr"></textarea>
    </div>
</div>

<!-- Pricing -->
<div class="bg-dark-900/50 border border-white/5 rounded-2xl p-6 space-y-5">
    <h2 class="font-bold text-lg border-b border-white/5 pb-3">@(isArabic ? "التسعير" : "Pricing")</h2>

    <div class="grid md:grid-cols-2 gap-5">
        <div>
            <label asp-for="Price" class="block text-sm font-medium text-dark-300 mb-1.5"></label>
            <input asp-for="Price" type="number" step="0.01"
                   class="w-full px-4 py-3 rounded-xl bg-dark-800 border border-white/5 text-white placeholder-dark-500 focus:outline-none focus:border-brand-500/40 focus:ring-1 focus:ring-brand-500/20 transition-all"
                   placeholder="499" dir="ltr" />
            <span asp-validation-for="Price" class="text-red-400 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="CompareAtPrice" class="block text-sm font-medium text-dark-300 mb-1.5"></label>
            <input asp-for="CompareAtPrice" type="number" step="0.01"
                   class="w-full px-4 py-3 rounded-xl bg-dark-800 border border-white/5 text-white placeholder-dark-500 focus:outline-none focus:border-brand-500/40 focus:ring-1 focus:ring-brand-500/20 transition-all"
                   placeholder="799" dir="ltr" />
            <p class="text-dark-500 text-xs mt-1">@(isArabic ? "اتركه فارغاً إذا لم يكن هناك خصم" : "Leave empty if no discount")</p>
        </div>
    </div>

    <div class="flex gap-6">
        <label class="flex items-center gap-2 cursor-pointer">
            <input asp-for="IsActive" type="checkbox" class="rounded border-white/10 bg-dark-800 text-brand-500 focus:ring-brand-500" />
            <span class="text-sm text-dark-300">@(isArabic ? "نشط (ظاهر للعملاء)" : "Active (visible to customers)")</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
            <input asp-for="IsFeatured" type="checkbox" class="rounded border-white/10 bg-dark-800 text-brand-500 focus:ring-brand-500" />
            <span class="text-sm text-dark-300">@(isArabic ? "مميز ⭐" : "Featured ⭐")</span>
        </label>
    </div>
</div>

<!-- File Uploads -->
<div class="bg-dark-900/50 border border-white/5 rounded-2xl p-6 space-y-5">
    <h2 class="font-bold text-lg border-b border-white/5 pb-3">@(isArabic ? "الملفات" : "Files")</h2>

    <!-- Cover Image Upload -->
    <div>
        <label class="block text-sm font-medium text-dark-300 mb-2">
            @(isArabic ? "صورة الغلاف" : "Cover Image")
        </label>
        <div class="border-2 border-dashed border-white/10 rounded-xl p-6 text-center hover:border-brand-500/30 transition-all cursor-pointer relative"
             @@click="$refs.coverInput.click()">
            <template x-if="!coverPreview">
                <div>
                    <svg class="w-10 h-10 text-dark-600 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <p class="text-dark-400 text-sm">@(isArabic ? "اضغط لرفع صورة الغلاف" : "Click to upload cover image")</p>
                    <p class="text-dark-600 text-xs mt-1">PNG, JPG, WEBP</p>
                </div>
            </template>
            <template x-if="coverPreview">
                <img :src="coverPreview" class="max-h-40 mx-auto rounded-lg" />
            </template>
            <input type="file" name="CoverImage" accept="image/*" class="hidden" x-ref="coverInput"
                   @@change="
                       if ($event.target.files[0]) {
                           const reader = new FileReader();
                           reader.onload = e => coverPreview = e.target.result;
                           reader.readAsDataURL($event.target.files[0]);
                       }
                   " />
        </div>
    </div>

    <!-- PDF Upload -->
    <div>
        <label class="block text-sm font-medium text-dark-300 mb-2">
            @(isArabic ? "ملف PDF للبرنامج" : "Program PDF File")
            @if (Model.Id == 0) { <span class="text-red-400">*</span> }
        </label>
        <div class="border-2 border-dashed border-white/10 rounded-xl p-6 text-center hover:border-brand-500/30 transition-all cursor-pointer relative"
             @@click="$refs.pdfInput.click()">
            <template x-if="!pdfName">
                <div>
                    <svg class="w-10 h-10 text-dark-600 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    </svg>
                    <p class="text-dark-400 text-sm">@(isArabic ? "اضغط لرفع ملف PDF" : "Click to upload PDF file")</p>
                    <p class="text-dark-600 text-xs mt-1">PDF @(isArabic ? "فقط" : "only")</p>
                </div>
            </template>
            <template x-if="pdfName">
                <div class="flex items-center justify-center gap-2">
                    <svg class="w-8 h-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    </svg>
                    <span class="text-dark-300 text-sm font-mono" x-text="pdfName"></span>
                    <span class="text-dark-500 text-xs">(@(isArabic ? "اضغط لتغيير" : "click to change"))</span>
                </div>
            </template>
            <input type="file" name="PdfFile" accept=".pdf" class="hidden" x-ref="pdfInput"
                   @@change="pdfName = $event.target.files[0]?.name || pdfName" />
        </div>
        <span asp-validation-for="PdfFile" class="text-red-400 text-xs mt-1 block"></span>
        @if (Model.Id > 0)
        {
            <p class="text-dark-500 text-xs mt-1">@(isArabic ? "اترك فارغاً للإبقاء على الملف الحالي" : "Leave empty to keep the current file")</p>
        }
    </div>
</div>
