@model IEnumerable<ElSheemyCoaching.Core.Entities.WorkoutProgram>
@using Microsoft.AspNetCore.Localization
@{
    ViewData["Title"] = "إدارة البرامج";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isArabic = requestCulture?.RequestCulture.Culture.Name.StartsWith("ar") ?? true;
}

<section class="max-w-7xl mx-auto px-4 py-10">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-2xl font-extrabold mb-1">@(isArabic ? "إدارة البرامج" : "Program Management")</h1>
            <p class="text-dark-400 text-sm">@(isArabic ? "إضافة وتعديل وحذف البرامج التدريبية" : "Add, edit, and delete training programs")</p>
        </div>
        <a href="@Url.Action("CreateProgram", "Admin")"
           class="px-5 py-2.5 rounded-xl bg-brand-600 hover:bg-brand-500 text-white font-medium text-sm transition-all flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            @(isArabic ? "إضافة برنامج" : "Add Program")
        </a>
    </div>

    <!-- Admin Nav -->
    <div class="flex gap-2 mb-6">
        <a href="@Url.Action("Orders", "Admin")"
           class="px-4 py-2 rounded-lg text-sm font-medium bg-dark-800 text-dark-400 hover:text-white border border-white/5 transition-all">
            @(isArabic ? "الطلبات" : "Orders")
        </a>
        <a href="@Url.Action("Programs", "Admin")"
           class="px-4 py-2 rounded-lg text-sm font-medium bg-brand-600/15 text-brand-400 border border-brand-500/20 transition-all">
            @(isArabic ? "البرامج" : "Programs")
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="bg-dark-900/50 border border-white/5 rounded-2xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-white/5 text-dark-400 text-sm">
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "الغلاف" : "Cover")</th>
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "العنوان" : "Title")</th>
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "السعر" : "Price")</th>
                            <th class="px-6 py-4 text-start font-medium">PDF</th>
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "الحالة" : "Status")</th>
                            <th class="px-6 py-4 text-start font-medium">@(isArabic ? "إجراءات" : "Actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var program in Model)
                        {
                            <tr class="border-b border-white/5 hover:bg-white/[0.02] transition-colors">
                                <td class="px-6 py-4">
                                    @if (!string.IsNullOrEmpty(program.CoverImageUrl))
                                    {
                                        <img src="@program.CoverImageUrl" alt="" class="w-14 h-14 rounded-lg object-cover" />
                                    }
                                    else
                                    {
                                        <div class="w-14 h-14 rounded-lg bg-dark-800 flex items-center justify-center">
                                            <svg class="w-6 h-6 text-dark-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                            </svg>
                                        </div>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <div class="font-medium">@(isArabic ? program.TitleAr : program.TitleEn)</div>
                                    <div class="text-dark-500 text-xs" dir="ltr">/@program.Slug</div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="font-bold text-brand-400">@program.Price.ToString("N0")</span>
                                    <span class="text-dark-500 text-xs">@(isArabic ? "ج.م" : "EGP")</span>
                                    @if (program.CompareAtPrice.HasValue)
                                    {
                                        <div class="text-dark-500 line-through text-xs">@program.CompareAtPrice.Value.ToString("N0")</div>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    @if (!string.IsNullOrEmpty(program.PrivateFilePath))
                                    {
                                        <span class="inline-flex items-center gap-1 text-xs text-emerald-400">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                            </svg>
                                            @(isArabic ? "مرفق" : "Attached")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-red-400 text-xs">@(isArabic ? "غير مرفق" : "Missing")</span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    @if (program.IsActive)
                                    {
                                        <span class="px-2 py-1 rounded-full bg-emerald-500/15 text-emerald-400 text-xs font-medium">
                                            @(isArabic ? "نشط" : "Active")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="px-2 py-1 rounded-full bg-dark-700 text-dark-400 text-xs font-medium">
                                            @(isArabic ? "غير نشط" : "Inactive")
                                        </span>
                                    }
                                    @if (program.IsFeatured)
                                    {
                                        <span class="px-2 py-1 rounded-full bg-amber-500/15 text-amber-400 text-xs font-medium ms-1">⭐</span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex gap-2">
                                        <a href="@Url.Action("EditProgram", "Admin", new { id = program.Id })"
                                           class="px-3 py-1.5 rounded-lg text-xs font-medium bg-blue-500/15 text-blue-400 hover:bg-blue-500/25 border border-blue-500/20 transition-all">
                                            @(isArabic ? "تعديل" : "Edit")
                                        </a>
                                        <form asp-controller="Admin" asp-action="DeleteProgram" asp-route-id="@program.Id" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="px-3 py-1.5 rounded-lg text-xs font-medium bg-red-500/15 text-red-400 hover:bg-red-500/25 border border-red-500/20 transition-all">
                                                @(isArabic ? "حذف (نقل للأرشيف)" : "Delete (Archive)")
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="bg-dark-900/50 border border-white/5 rounded-2xl p-12 text-center">
            <svg class="w-16 h-16 text-dark-700 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            <p class="text-dark-500 mb-4">@(isArabic ? "لا توجد برامج بعد" : "No programs yet")</p>
            <a href="@Url.Action("CreateProgram", "Admin")"
               class="inline-block px-5 py-2.5 rounded-xl bg-brand-600 hover:bg-brand-500 text-white font-medium text-sm transition-all">
                @(isArabic ? "أضف أول برنامج" : "Add First Program")
            </a>
        </div>
    }
</section>
