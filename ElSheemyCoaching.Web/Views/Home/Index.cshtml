@model IEnumerable<ElSheemyCoaching.Core.Entities.Transformation>
@using Microsoft.AspNetCore.Localization
@{
    ViewData["Title"] = "الرئيسية";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isArabic = requestCulture?.RequestCulture.Culture.Name.StartsWith("ar") ?? true;
    var dir = isArabic ? "rtl" : "ltr";
}

<!-- ═══════════ HERO SECTION ═══════════ -->
<section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-950/50 via-dark-950 to-dark-950"></div>
    <div class="absolute inset-0">
        <div class="absolute top-20 start-10 w-72 h-72 bg-brand-600/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-10 end-10 w-96 h-96 bg-brand-500/5 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 py-24 sm:py-32 text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight">
            @if (isArabic)
            {
                <span>حوّل جسمك و صحتك مع</span>
                <br />
                <span class="bg-gradient-to-r from-brand-400 to-brand-600 bg-clip-text text-transparent">
                    دكتور الشيمي
                </span>
            }
            else
            {
                <span>Transform Your Body and Health with</span>
                <br />
                <span class="bg-gradient-to-r from-brand-400 to-brand-600 bg-clip-text text-transparent">
                    Doctor ElShemy
                </span>
            }
        </h1>
        <p class="text-lg sm:text-xl text-dark-300 max-w-2xl mx-auto mb-10">
            @(isArabic
                ? "طبيب X مدرب X اخ وصديق = نتائج حقيقية"
                : "Doctor × Coach × Brother & Friend = Real Results.")
        </p>
        <a href="@Url.Action("Index", "Programs")"
           class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-gradient-to-r from-brand-600 to-brand-500 hover:from-brand-500 hover:to-brand-400 text-white font-semibold text-lg transition-all transform hover:scale-105 shadow-lg shadow-brand-600/25">
            @(isArabic ? "تصفح البرامج" : "Browse Programs")
            <svg class="w-5 h-5 @(isArabic ? "rotate-180" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
        </a>
    </div>
</section>

<!-- ═══════════ TRANSFORMATIONS SECTION ═══════════ -->
<section class="bg-dark-900/40 border-y border-white/5 py-24 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
            <h2 class="text-3xl sm:text-4xl font-extrabold mb-4">
                <span class="bg-gradient-to-r from-brand-400 to-brand-600 bg-clip-text text-transparent">
                    @(isArabic ? "قصص نجاح" : "Success Stories")
                </span>
            </h2>
            <p class="text-dark-400 max-w-2xl mx-auto">
                @(isArabic ? "شاهد النتائج الحقيقية لعملائنا قبل وبعد الالتزام ببرامجنا التدريبية." : "See the real before-and-after results of our clients who committed to our programs.")
            </p>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="space-y-16">
                @foreach (var t in Model)
                {
                    <div class="bg-dark-800/50 rounded-[2rem] p-6 md:p-10 border border-white/5 mx-auto w-full max-w-5xl shadow-2xl">
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-10 items-center">
                            <!-- Before / After Grid -->
                            <div class="grid grid-cols-2 gap-3 sm:gap-4 h-full">
                                <!-- Before -->
                                <div class="relative group/img overflow-hidden rounded-2xl aspect-[3/4] shadow-lg border border-white/5">
                                    <img src="@t.BeforeImageUrl" alt="Before" class="w-full h-full object-cover transition-transform duration-700 group-hover/img:scale-110" />
                                    <div class="absolute inset-0 bg-gradient-to-t from-dark-950/80 via-transparent to-transparent opacity-60"></div>
                                    <div class="absolute bottom-4 inset-x-0 text-center">
                                        <span class="px-3 py-1 bg-dark-900/80 backdrop-blur-md text-white text-[10px] sm:text-xs font-black tracking-widest rounded-full border border-white/10 shadow-xl">BEFORE</span>
                                    </div>
                                </div>
                                
                                <!-- After -->
                                <div class="relative group/img overflow-hidden rounded-2xl aspect-[3/4] shadow-lg border border-brand-500/20">
                                    <img src="@t.AfterImageUrl" alt="After" class="w-full h-full object-cover transition-transform duration-700 group-hover/img:scale-110" />
                                    <div class="absolute inset-0 bg-gradient-to-t from-brand-950/40 via-transparent to-transparent opacity-40"></div>
                                    <div class="absolute bottom-4 inset-x-0 text-center">
                                        <span class="px-3 py-1 bg-brand-600/90 backdrop-blur-md text-white text-[10px] sm:text-xs font-black tracking-widest rounded-full border border-white/10 shadow-xl">AFTER</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Info Section -->
                            <div class="text-center md:text-start space-y-4">
                                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-600/10 text-brand-400 text-xs font-bold border border-brand-500/20 mb-2">
                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                    @(isArabic ? "قصة تحول ملهمة" : "Inspiring Transformation")
                                </div>
                                <h3 class="text-2xl md:text-3xl font-black text-white leading-tight">@(isArabic ? t.TitleAr : t.TitleEn)</h3>
                                <div class="w-12 h-1 bg-brand-500 rounded-full mx-auto md:mx-0"></div>
                                <p class="text-dark-300 text-base md:text-lg leading-relaxed pt-2">
                                    @(isArabic ? t.DescriptionAr : t.DescriptionEn)
                                </p>
                                
                                <div class="pt-6">
                                    <a href="@Url.Action("Index", "Programs")" 
                                       class="inline-flex items-center gap-2 text-brand-400 hover:text-brand-300 font-bold transition-all group/btn">
                                        @(isArabic ? "ابدأ قصتك الخاصة" : "Start Your Story")
                                        <svg class="w-5 h-5 transition-transform group-hover/btn:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- Empty State View -->
            <div class="bg-dark-800/50 border border-white/5 rounded-3xl p-12 text-center mt-8 mx-auto max-w-2xl">
                <svg class="w-16 h-16 text-brand-500/50 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <h3 class="text-xl font-bold text-white mb-2">@(isArabic ? "قريباً جداً" : "Coming Soon")</h3>
                <p class="text-dark-400 leading-relaxed">@(isArabic ? "سيتم إضافة قصص نجاح ملهمة قريباً. كن أنت القصة القادمة!" : "Inspiring success stories will be added soon. Be the next hero!")</p>
            </div>
        }
    </div>
</section>



<!-- ═══════════ FEATURES SECTION ═══════════ -->
<section class="max-w-7xl mx-auto px-4 py-20">
    <div class="grid md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="bg-dark-900/50 border border-white/5 rounded-2xl p-8 hover:border-brand-500/20 transition-all group">
            <div class="w-14 h-14 rounded-xl bg-brand-600/10 flex items-center justify-center mb-6 group-hover:bg-brand-600/20 transition-all">
                <svg class="w-7 h-7 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">@(isArabic ? "برامج احترافية" : "Professional Programs")</h3>
            <p class="text-dark-400 leading-relaxed">
                @(isArabic
                    ? "برامج تدريب مصممة بعناية من قبل مدربين معتمدين لتناسب جميع المستويات."
                    : "Carefully designed training programs by certified coaches for all fitness levels.")
            </p>
        </div>

        <!-- Feature 2 -->
        <div class="bg-dark-900/50 border border-white/5 rounded-2xl p-8 hover:border-brand-500/20 transition-all group">
            <div class="w-14 h-14 rounded-xl bg-brand-600/10 flex items-center justify-center mb-6 group-hover:bg-brand-600/20 transition-all">
                <svg class="w-7 h-7 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">@(isArabic ? "دفع آمن" : "Secure Payment")</h3>
            <p class="text-dark-400 leading-relaxed">
                @(isArabic
                    ? "ادفع بسهولة عبر InstaPay واحصل على برنامجك فور التأكيد."
                    : "Pay easily via InstaPay and get your program immediately after confirmation.")
            </p>
        </div>

        <!-- Feature 3 -->
        <div class="bg-dark-900/50 border border-white/5 rounded-2xl p-8 hover:border-brand-500/20 transition-all group">
            <div class="w-14 h-14 rounded-xl bg-brand-600/10 flex items-center justify-center mb-6 group-hover:bg-brand-600/20 transition-all">
                <svg class="w-7 h-7 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">@(isArabic ? "تحميل فوري" : "Instant Download")</h3>
            <p class="text-dark-400 leading-relaxed">
                @(isArabic
                    ? "حمّل البرنامج بصيغة PDF بعد الموافقة على الدفع مباشرة."
                    : "Download the program as PDF immediately after payment approval.")
            </p>
        </div>
    </div>
</section>
