@model IEnumerable<ElSheemyCoaching.Core.Entities.Transformation>
@using Microsoft.AspNetCore.Localization
@{
    ViewData["Title"] = "الرئيسية";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isArabic = requestCulture?.RequestCulture.Culture.Name.StartsWith("ar") ?? true;
    var dir = isArabic ? "rtl" : "ltr";
}

<style>
    /* ── Scroll-reveal base ── */
    .reveal {
        opacity: 0;
        transform: translateY(36px);
        transition: opacity 0.7s cubic-bezier(.22,.84,.24,1), transform 0.7s cubic-bezier(.22,.84,.24,1);
    }
    .reveal.visible {
        opacity: 1;
        transform: translateY(0);
    }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }
    .reveal-delay-5 { transition-delay: 0.5s; }

    /* ── Brand logo mark ── */
    .brand-logo {
        display: inline-flex;
        align-items: baseline;
        gap: 0;
        font-weight: 900;
        letter-spacing: -0.03em;
        line-height: 1;
    }
    .brand-logo .logo-name {
        background: linear-gradient(135deg, #ffffff 30%, #f59e0b 80%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        font-style: italic;
    }
    .brand-logo .logo-dot {
        width: 6px;
        height: 6px;
        background: #f59e0b;
        border-radius: 50%;
        display: inline-block;
        margin-bottom: 4px;
        margin-right: 1px;
        flex-shrink: 0;
        align-self: flex-end;
    }
    .brand-logo .logo-dr {
        display: none; /* We'll include it in the logo-name text */
    }

    /* Hero brand display (larger) */
    .hero-brand-ar {
        font-size: 1em;
        display: inline-flex;
        align-items: baseline;
        gap: 0;
    }

    /* ── Scroll progress bar ── */
    #scroll-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 3px;
        width: 0%;
        background: linear-gradient(90deg, #f59e0b, #f97316);
        z-index: 9999;
        transition: width 0.1s linear;
        border-radius: 0 2px 2px 0;
    }

    /* ── Floating nav dot ── */
    .section-nav {
        position: fixed;
        right: 1.5rem;
        top: 50%;
        transform: translateY(-50%);
        display: flex;
        flex-direction: column;
        gap: 10px;
        z-index: 100;
    }
    .section-nav a {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        border: 1.5px solid rgba(255,255,255,0.3);
        transition: all 0.3s;
        display: block;
    }
    .section-nav a.active {
        background: #f59e0b;
        border-color: #f59e0b;
        transform: scale(1.4);
    }
   

    /* ── Hero parallax orbs ── */
    .orb {
        position: absolute;
        border-radius: 50%;
        will-change: transform;
        pointer-events: none;
    }

    /* ── Transformation card ── */
    .transform-card {
        opacity: 0;
        transform: translateY(50px);
        transition: opacity 0.8s cubic-bezier(.22,.84,.24,1), transform 0.8s cubic-bezier(.22,.84,.24,1);
    }
    .transform-card.visible {
        opacity: 1;
        transform: translateY(0);
    }
    .transform-card:nth-child(even) {
        transition-delay: 0.15s;
    }

    /* ── Feature cards hover lift ── */
    .feature-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }
    .feature-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }

    /* ── Stats counter ── */
    .stat-number {
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum";
    }

    /* ── Custom Scrollbar ── */
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: rgba(255,255,255,0.02); }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(245,158,11,0.2); border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(245,158,11,0.4); }

    /* ── Enhanced Reveals ── */
    .reveal-left { transform: translateX(-30px); opacity: 0; transition: all 0.8s cubic-bezier(.22,.84,.24,1); }
    .reveal-right { transform: translateX(30px); opacity: 0; transition: all 0.8s cubic-bezier(.22,.84,.24,1); }
    .reveal-scale { transform: scale(0.95); opacity: 0; transition: all 0.8s cubic-bezier(.22,.84,.24,1); }
    
    .reveal-left.visible, .reveal-right.visible, .reveal-scale.visible {
        transform: translate(0) scale(1);
        opacity: 1;
    }

    /* Mobile adjustments */
    @@media (max-width: 640px) {
        .brand-logo.hero-brand-ar { font-size: 0.85em; }
        .logo-dr { font-size: 0.4em !important; }
    }
</style>

<!-- Scroll progress bar -->
<div id="scroll-progress"></div>

<!-- Section nav dots -->
<nav class="section-nav" aria-label="Section navigation">
    <a href="#hero" data-section="hero" class="active" title="Hero"></a>
    <a href="#transformations" data-section="transformations" title="Transformations"></a>
    <a href="#features" data-section="features" title="Features"></a>
</nav>

<!-- ═══════════ HERO SECTION ═══════════ -->
<section id="hero" class="relative overflow-hidden min-h-screen flex items-center">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-950/60 via-dark-950 to-dark-950"></div>

    <!-- Animated orbs -->
    <div class="orb w-[500px] h-[500px] bg-amber-500/8 top-[-100px] start-[-100px] blur-3xl" data-speed="0.04"></div>
    <div class="orb w-[350px] h-[350px] bg-brand-600/10 bottom-[-50px] end-[-80px] blur-3xl" data-speed="0.06"></div>
    <div class="orb w-[200px] h-[200px] bg-orange-500/6 top-[40%] start-[30%] blur-2xl" data-speed="0.03"></div>

    <!-- Subtle grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]"
         style="background-image: linear-gradient(rgba(255,255,255,.5) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.5) 1px,transparent 1px);background-size:48px 48px;"></div>

    <div class="relative max-w-7xl mx-auto px-4 py-32 sm:py-40 text-center w-full">

        <!-- Profile Image -->
        <div class="reveal mb-10 flex justify-center">
            <div class="relative group">
                <div class="relative w-40 h-40 sm:w-56 sm:h-56 rounded-full p-1 bg-gradient-to-tr from-amber-500 via-orange-500 to-amber-500 shadow-2xl shadow-amber-500/40 transform transition-transform group-hover:scale-105 duration-500">
                    <div class="w-full h-full rounded-full overflow-hidden border-4 border-dark-950">
                        <img src="/images/dr-elshemy.jpeg" alt="Dr. ElShemy" class="w-full h-full object-cover object-top" />
                    </div>
                </div>

            </div>
        </div>

        <!-- Brand eyebrow -->
        <div class="reveal inline-flex items-center gap-2 px-4 py-2 rounded-full mb-8
            bg-amber-500/10 border border-amber-500/20 text-amber-400 text-sm font-semibold tracking-wide">
            <span class="pulse-badge w-2 h-2 bg-amber-400 rounded-full inline-block"></span>
            @(isArabic ? "صحتك هتتحسن مش بس جسمك مع دكتور الشيمي" : "your health will improve, not just your body, with Dr. El Shemy")
        </div>

        <!-- Main headline -->
        <h1 class="reveal reveal-delay-1 text-4xl sm:text-5xl lg:text-7xl font-extrabold mb-6 leading-[1.08] tracking-tight">
            @if (isArabic)
            {
                <span class="block text-white mb-2">حوّل جسمك وصحتك</span>
                <span class="block">
                    مع&nbsp;
                    <span class="block text-white mb-">
                        <span class="logo-name">د. الشيمي</span>
                    </span>
                </span>
            }
            else
            {
                <span class="block text-white mb-2">Transform Your Body</span>
                <span class="block">
                    With&nbsp;
                    <span class="block text-white mb-2">
                        <span class="logo-name">Dr. ELSHEMY</span>
                    </span>
                </span>
            }
        </h1>

        <p class="reveal reveal-delay-2 text-lg sm:text-xl text-dark-300 max-w-xl mx-auto mb-4">
            @(isArabic
                ? "طبيب × مدرب × أخ وصديق"
                : "Doctor × Coach × Brother & Friend")
        </p>
        <p class="reveal reveal-delay-2 text-base text-amber-400/80 font-semibold mb-12 tracking-wide">
            @(isArabic ? "= نتائج حقيقية مضمونة" : "= Real, Guaranteed Results")
        </p>

        <!-- CTA buttons -->
        <div class="reveal-scale reveal-delay-3 flex flex-col sm:flex-row gap-4 justify-center items-center">
            <a href="@Url.Action("Index", "Programs")"
                   class="inline-flex items-center gap-2 px-8 py-4 rounded-xl
                bg-gradient-to-r from-amber-500 to-orange-500
                hover:from-amber-400 hover:to-orange-400
                text-white font-bold text-lg transition-all
                transform hover:scale-105 hover:-translate-y-0.5
                shadow-lg shadow-amber-500/25">
                @(isArabic ? "تصفح البرامج" : "Browse Programs")
                <svg class="w-5 h-5 @(isArabic ? "rotate-180" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
            </a>
            <a href="#transformations"
                   class="inline-flex items-center gap-2 px-8 py-4 rounded-xl
                border border-white/10 hover:border-white/20
                text-white/70 hover:text-white font-semibold text-base
                transition-all hover:bg-white/5">
                @(isArabic ? "شاهد قصص النجاح" : "See Success Stories")
                <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
            </a>
        </div>

        <!-- Elastic Search Bar -->
        <div class="reveal reveal-delay-3 max-w-2xl mx-auto mt-12 relative" x-data="searchApp()">
            <div class="relative group">
                <input type="text" 
                       x-model="query"
                       @@input.debounce.300ms="performSearch()"
                       placeholder="@(isArabic ? "ابحث عن برنامجك أو قصة نجاحنا..." : "Search for your program or success story...")"
                       class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 @(isArabic ? "pr-14 pl-6" : "pl-14 pr-6") 
                              text-white placeholder-white/30 focus:outline-none focus:ring-2 focus:ring-amber-500/50 focus:border-amber-500/50 
                              transition-all duration-300 backdrop-blur-xl group-hover:bg-white/10" />
                <div class="absolute inset-y-0 @(isArabic ? "right-5" : "left-5") flex items-center pointer-events-none">
                    <svg class="w-5 h-5 text-amber-500/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>
                
                <!-- Loading indicator -->
                <div x-show="loading" class="absolute inset-y-0 @(isArabic ? "left-5" : "right-5") flex items-center">
                    <div class="w-4 h-4 border-2 border-amber-500/30 border-t-amber-500 rounded-full animate-spin"></div>
                </div>
            </div>

            <!-- Search Results Overlay -->
            <div x-show="resultsOpen" 
                 @@click.away="resultsOpen = false"
                 x-transition:enter="transition ease-out duration-200"
                 x-transition:enter-start="opacity-0 translate-y-4 scale-95"
                 x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                 class="absolute top-full left-0 right-0 mt-4 bg-dark-900/95 backdrop-blur-2xl border border-white/10 rounded-2xl shadow-2xl z-[1000] overflow-hidden">
                
                <div class="max-h-[min(450px,70vh)] overflow-y-auto custom-scrollbar p-2">
                    <template x-if="results.programs.length === 0 && results.transformations.length === 0 && query.length >= 2 && !loading">
                        <div class="p-8 text-center">
                            <p class="text-dark-400 text-sm">@(isArabic ? "لا توجد نتائج مطابقة لبحثك." : "No results found matching your search.")</p>
                        </div>
                    </template>

                    <!-- Programs Group -->
                    <template x-if="results.programs.length > 0">
                        <div class="mb-4">
                            <h4 class="text-[10px] font-bold text-amber-500/60 uppercase tracking-widest px-4 py-2 border-b border-white/5">@(isArabic ? "البرامج" : "Programs")</h4>
                            <div class="grid gap-1 mt-2">
                                <template x-for="p in results.programs" :key="p.url">
                                    <a :href="p.url" class="flex items-center gap-4 p-3 rounded-xl hover:bg-white/5 transition-colors group/item">
                                        <div class="w-12 h-12 rounded-lg overflow-hidden flex-shrink-0 border border-white/5">
                                            <img :src="p.image" class="w-full h-full object-cover" />
                                        </div>
                                        <div class="flex-1">
                                            <p class="text-sm font-bold text-white group-hover/item:text-amber-400 transition-colors" x-text="p.title"></p>
                                            <p class="text-[10px] text-dark-500" x-text="p.type"></p>
                                        </div>
                                        <svg class="w-4 h-4 text-dark-500 group-hover/item:text-amber-500 transition-all transform @(isArabic ? "rotate-180" : "") group-hover/item:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                                        </svg>
                                    </a>
                                </template>
                            </div>
                        </div>
                    </template>

                    <!-- Transformations Group -->
                    <template x-if="results.transformations.length > 0">
                        <div>
                            <h4 class="text-[10px] font-bold text-amber-500/60 uppercase tracking-widest px-4 py-2 border-b border-white/5">@(isArabic ? "قصص التحول" : "Transformations")</h4>
                            <div class="grid gap-1 mt-2">
                                <template x-for="t in results.transformations" :key="t.url">
                                    <a :href="t.url" class="flex items-center gap-4 p-3 rounded-xl hover:bg-white/5 transition-colors group/item">
                                        <div class="w-12 h-12 rounded-lg overflow-hidden flex-shrink-0 border border-white/5">
                                            <img :src="t.image" class="w-full h-full object-cover" />
                                        </div>
                                        <div class="flex-1">
                                            <p class="text-sm font-bold text-white group-hover/item:text-amber-400 transition-colors" x-text="t.title"></p>
                                            <p class="text-[10px] text-dark-500" x-text="t.type"></p>
                                        </div>
                                        <svg class="w-4 h-4 text-dark-500 group-hover/item:text-amber-500 transition-all transform @(isArabic ? "rotate-180" : "") group-hover/item:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                                        </svg>
                                    </a>
                                </template>
                            </div>
                        </div>
                    </template>
                </div>
            </div>
        </div>

        <!-- Quick stats -->
        <div class="reveal reveal-delay-4 grid grid-cols-3 gap-4 sm:gap-8 max-w-lg mx-auto mt-20
            border-t border-white/5 pt-10">
            <div class="text-center">
                <p class="text-2xl sm:text-3xl font-black text-white stat-number" data-count="50">0+</p>
                <p class="text-xs sm:text-sm text-dark-400 mt-1">@(isArabic ? "عميل ناجح" : "Happy Clients")</p>
            </div>
            <div class="text-center border-x border-white/5">
                <p class="text-2xl sm:text-3xl font-black text-white stat-number" data-count="5">0+</p>
                <p class="text-xs sm:text-sm text-dark-400 mt-1">@(isArabic ? "سنوات خبرة" : "Years Exp.")</p>
            </div>
            <div class="text-center">
                <p class="text-2xl sm:text-3xl font-black text-white stat-number" data-count="98">0%</p>
                <p class="text-xs sm:text-sm text-dark-400 mt-1">@(isArabic ? "رضا العملاء" : "Satisfaction")</p>
            </div>
        </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
        <span class="text-xs text-white tracking-widest uppercase">@(isArabic ? "اسحب للأسفل" : "Scroll")</span>
        <div class="w-px h-10 bg-gradient-to-b from-white/50 to-transparent animate-pulse"></div>
    </div>
</section>

<!-- ═══════════ TRANSFORMATIONS SECTION ═══════════ -->
<section id="transformations" class="bg-dark-900/40 border-y border-white/5 py-28 relative overflow-hidden">
    <!-- Background accent -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-20 bg-gradient-to-b from-transparent via-amber-500/40 to-transparent"></div>

    <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-20 reveal">
            <p class="text-amber-400 text-sm font-bold tracking-[0.2em] uppercase mb-3">
                @(isArabic ? "النتائج تتحدث" : "Results Speak")
            </p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold mb-4 tracking-tight">
                @(isArabic ? "قصص تحول حقيقية" : "Real Transformations")
            </h2>
            <div class="section-divider"></div>
            <p class="text-dark-400 max-w-xl mx-auto text-base">
                @(isArabic
                    ? "شاهد النتائج الحقيقية لعملائنا الذين التزموا ببرامجنا."
                    : "See the real before-and-after results of clients who committed to our programs.")
            </p>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="space-y-14">
                @{
                    int cardIdx = 0;
                }
                @foreach (var t in Model)
                {
                    cardIdx++;
                    <div class="transform-card bg-dark-800/50 rounded-[2rem] p-6 md:p-10
                        border border-white/5 mx-auto w-full max-w-5xl shadow-2xl
                        hover:border-amber-500/10 transition-colors duration-500">

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-12 items-center">
                            <!-- Before / After images -->
                            <div class="grid grid-cols-2 gap-3 sm:gap-4">
                                <!-- Before -->
                                <div class="relative group/img overflow-hidden rounded-2xl aspect-[3/4] shadow-lg border border-white/5">
                                    <img src="@t.BeforeImageUrl" alt="Before"
                                         class="w-full h-full object-cover transition-transform duration-700 group-hover/img:scale-110" />
                                    <div class="absolute inset-0 bg-gradient-to-t from-dark-950/80 via-transparent to-transparent"></div>
                                    <div class="absolute bottom-4 inset-x-0 text-center">
                                        <span class="px-3 py-1 bg-dark-900/80 backdrop-blur-md text-white/70 text-[10px] sm:text-xs font-black tracking-widest rounded-full border border-white/10">
                                            BEFORE
                                        </span>
                                    </div>
                                </div>

                                <!-- After -->
                                <div class="relative group/img overflow-hidden rounded-2xl aspect-[3/4] shadow-lg border border-amber-500/20">
                                    <img src="@t.AfterImageUrl" alt="After"
                                         class="w-full h-full object-cover transition-transform duration-700 group-hover/img:scale-110" />
                                    <div class="absolute inset-0 bg-gradient-to-t from-amber-950/30 via-transparent to-transparent"></div>
                                    <div class="absolute bottom-4 inset-x-0 text-center">
                                        <span class="px-3 py-1 bg-amber-500/90 backdrop-blur-md text-white text-[10px] sm:text-xs font-black tracking-widest rounded-full">
                                            AFTER
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <!-- Info -->
                            <div class="text-center md:text-start space-y-4">
                                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full
                                    bg-amber-500/10 text-amber-400 text-xs font-bold
                                    border border-amber-500/20">
                                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                    </svg>
                                    @(isArabic ? "قصة تحول ملهمة" : "Inspiring Transformation")
                                </div>

                                <h3 class="text-2xl md:text-3xl font-black text-white leading-tight">
                                    @(isArabic? t.TitleAr: t.TitleEn)
                                </h3>

                                <div class="w-12 h-1 bg-gradient-to-r from-amber-400 to-orange-500 rounded-full mx-auto md:mx-0"></div>

                                <p class="text-dark-300 text-base md:text-lg leading-relaxed pt-1">
                                    @(isArabic? t.DescriptionAr: t.DescriptionEn)
                                </p>

                                <div class="pt-5">
                                    <a href="@Url.Action("Index", "Programs")"
                                           class="inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 font-bold transition-all group/btn">
                                        @(isArabic ? "ابدأ قصتك الخاصة" : "Start Your Story")
                                        <svg class="w-5 h-5 transition-transform group-hover/btn:translate-x-1 @(isArabic ? "rotate-180" : "")"
                                             fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="reveal bg-dark-800/50 border border-white/5 rounded-3xl p-14 text-center mx-auto max-w-xl">
                <div class="w-16 h-16 rounded-2xl bg-amber-500/10 flex items-center justify-center mx-auto mb-5">
                    <svg class="w-8 h-8 text-amber-500/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
